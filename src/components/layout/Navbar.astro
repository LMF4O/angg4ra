---
import LanguageToggle from '../ui/LanguageToggle.astro';

const { lang = 'id', currentPath } = Astro.props;

const navLinks = lang === 'id'
  ? [
      { href: `/${lang}/about`,      label: 'Tentang' },
      { href: `/${lang}/projects`,   label: 'Proyek' },
      { href: `/${lang}/skills`,     label: 'Skill' },
      { href: `/${lang}/experience`, label: 'Pengalaman' },
      { href: `/${lang}/blog`,       label: 'Blog' },
      { href: `/${lang}/contact`,    label: 'Kontak' },
    ]
  : [
      { href: `/${lang}/about`,      label: 'About' },
      { href: `/${lang}/projects`,   label: 'Projects' },
      { href: `/${lang}/skills`,     label: 'Skills' },
      { href: `/${lang}/experience`, label: 'Experience' },
      { href: `/${lang}/blog`,       label: 'Blog' },
      { href: `/${lang}/contact`,    label: 'Contact' },
    ];
---

<nav class="navbar">
  <div class="nav-inner">
    <!-- Logo -->
    <a href={`/${lang}/`} class="nav-logo">
      <span class="font-mono text-data">argy</span><span class="font-mono text-secondary">.dev</span>
    </a>

    <!-- Links -->
    <ul class="nav-links">
      {navLinks.map(link => (
        <li class="nav-item">
          <a
            href={link.href}
            class={`nav-link font-mono ${currentPath === link.href ? 'active' : ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language Toggle -->
    <LanguageToggle currentLang={lang} currentPath={currentPath} />
  </div>
</nav>

<style is:global>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(10, 9, 8, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-size: 1rem;
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 200ms ease;
  }
  .nav-logo:hover { opacity: 0.75; }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.75rem;
    margin-left: auto;
    padding: 0;
    margin-right: 0;
  }

  .nav-item { position: relative; }

  .nav-link {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.03em;
    padding-bottom: 4px;
    position: relative;
    transition: color 200ms ease;
    display: inline-block;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1px;
    background-color: var(--accent-data);
    border-radius: 999px;
    transition: width 250ms ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--text-primary);
  }
  .nav-link.active::after {
    width: 100%;
    background-color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
  }
</style>