---
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import '../../styles/global.css';

const { title = 'Argy Anggara', lang = 'id' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Portfolio Argy Anggara — Data Analyst & Data Scientist" />
  <title>{title} | Argy Anggara</title>

  <!-- Preconnect ke Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Load font stylesheet (INI yang kurang!) -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&family=Cormorant+Garamond:ital,wght@1,400;1,600&display=swap" rel="stylesheet" />

  <style is:global>
    /* ── TERMINAL EASTER EGG — MODAL ────────────────────── */

    /* Overlay: fullscreen backdrop */
    #terminal-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 9999;
      align-items: center; justify-content: center;
      background: rgba(0, 0, 0, 0.82);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    #terminal-overlay.visible { opacity: 1; }

    /* Window: modal card */
    #terminal-window {
      width: min(740px, 94vw);
      max-height: min(600px, 88vh);
      background: #0A0907;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.04),
        0 24px 60px rgba(0, 0, 0, 0.85),
        0 8px 24px rgba(0, 0, 0, 0.6);
      display: flex;
      flex-direction: column;
      font-family: 'JetBrains Mono', monospace;
      overflow: hidden;
      /* Entry animation: slides up + scales in */
      transform: translateY(28px) scale(0.96);
      transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
    }
    #terminal-overlay.visible #terminal-window {
      transform: translateY(0) scale(1);
    }

    /* Title bar */
    #terminal-titlebar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 1rem;
      background: #0F0D0A;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      flex-shrink: 0;
      user-select: none;
    }
    .t-dots { display: flex; gap: 6px; align-items: center; }
    .t-dot {
      width: 12px; height: 12px; border-radius: 50%;
      cursor: pointer;
      transition: filter 0.15s, transform 0.15s;
    }
    .t-dot:hover { filter: brightness(1.5); transform: scale(1.1); }
    .t-red    { background: #6B2D2D; }
    .t-yellow { background: #6B5F2D; }
    .t-green  { background: #2D6B3A; }
    .t-title {
      flex: 1;
      font-size: 0.7rem;
      color: rgba(255, 255, 255, 0.3);
      letter-spacing: 0.08em;
      text-align: center;
    }
    .t-hint {
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.12);
      letter-spacing: 0.06em;
    }

    /* Output area */
    #terminal-output {
      flex: 1;
      overflow-y: auto;
      padding: 1rem 1.25rem 0.5rem;
      min-height: 160px;
      scrollbar-width: thin;
      scrollbar-color: rgba(255,255,255,0.07) transparent;
    }
    #terminal-output::-webkit-scrollbar { width: 3px; }
    #terminal-output::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.07);
      border-radius: 99px;
    }

    /* Lines */
    .t-line {
      font-size: 0.775rem;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.5);
      white-space: pre-wrap;
      word-break: break-word;
    }
    .t-boot { color: rgba(106, 143, 110, 0.85); }
    .t-cmd  { color: rgba(255, 255, 255, 0.88); }
    .t-err  { color: rgba(180, 80, 80, 0.9); }
    .t-dir  { color: #4A8FA0; }

    /* Input row */
    #terminal-input-line {
      display: flex;
      align-items: center;
      padding: 0.65rem 1.25rem;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      flex-shrink: 0;
      background: #0A0907;
    }
    #terminal-prompt {
      font-size: 0.775rem;
      color: #6A8F6E;
      white-space: nowrap;
      flex-shrink: 0;
      margin-right: 0;
    }
    #terminal-input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      font-size: 0.775rem;
      color: rgba(255, 255, 255, 0.88);
      font-family: 'JetBrains Mono', monospace;
      caret-color: #6A8F6E;
    }

    /* Mobile adjustments */
    @media (max-width: 480px) {
      #terminal-window { width: 98vw; max-height: 85vh; border-radius: 8px; }
      .t-line, #terminal-prompt, #terminal-input { font-size: 0.7rem; }
    }
  </style>
</head>
<body>
  <Navbar lang={lang} currentPath={Astro.url.pathname} />

  <main>
    <slot />
  </main>

  <Footer lang={lang} />

  <!-- Script GSAP global -->
  <script>
    import '../../scripts/gsap-animations.js';
    import '../../scripts/terminal.js';
  </script>
</body>
</html>