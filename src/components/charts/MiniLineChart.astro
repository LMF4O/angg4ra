---
// MiniLineChart.astro
// Dekoratif SVG chart animated — dipakai sebagai background di Hero
// Props opsional untuk kustomisasi
interface Props {
  class?: string;
}
---

<div class="chart-wrap" aria-hidden="true">
  <svg
    class="chart-svg"
    viewBox="0 0 900 220"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <!-- Gradient fade kiri-kanan -->
      <linearGradient id="fade-lr" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="#0A0908" stop-opacity="1"/>
        <stop offset="15%"  stop-color="#0A0908" stop-opacity="0"/>
        <stop offset="85%"  stop-color="#0A0908" stop-opacity="0"/>
        <stop offset="100%" stop-color="#0A0908" stop-opacity="1"/>
      </linearGradient>

      <!-- Gradient fill area bawah garis utama -->
      <linearGradient id="fill-main" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%"   stop-color="#6B2D3E" stop-opacity="0.12"/>
        <stop offset="100%" stop-color="#6B2D3E" stop-opacity="0"/>
      </linearGradient>

      <!-- Gradient fill area bawah garis kedua -->
      <linearGradient id="fill-sci" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%"   stop-color="#3A6B7A" stop-opacity="0.08"/>
        <stop offset="100%" stop-color="#3A6B7A" stop-opacity="0"/>
      </linearGradient>

      <!-- Clip path biar draw animation bisa dipakai -->
      <clipPath id="reveal-clip">
        <rect class="reveal-rect" x="0" y="0" width="0" height="220"/>
      </clipPath>
    </defs>

    <!-- Grid lines horizontal — subtle -->
    <line x1="0" y1="55"  x2="900" y2="55"  stroke="#1E1C14" stroke-width="1"/>
    <line x1="0" y1="110" x2="900" y2="110" stroke="#1E1C14" stroke-width="1"/>
    <line x1="0" y1="165" x2="900" y2="165" stroke="#1E1C14" stroke-width="1"/>

    <!-- Grid lines vertikal -->
    <line x1="180" y1="0" x2="180" y2="220" stroke="#1E1C14" stroke-width="1" stroke-dasharray="3 4"/>
    <line x1="360" y1="0" x2="360" y2="220" stroke="#1E1C14" stroke-width="1" stroke-dasharray="3 4"/>
    <line x1="540" y1="0" x2="540" y2="220" stroke="#1E1C14" stroke-width="1" stroke-dasharray="3 4"/>
    <line x1="720" y1="0" x2="720" y2="220" stroke="#1E1C14" stroke-width="1" stroke-dasharray="3 4"/>

    <!-- Semua konten dalam clip (draw effect) -->
    <g clip-path="url(#reveal-clip)">

      <!-- Fill area garis ketiga (paling bawah, background) -->
      <path
        class="chart-path"
        d="M0,195 C60,188 120,182 180,175 C240,168 300,160 360,170 C420,180 480,172 540,158 C600,144 660,136 720,145 C780,154 840,148 900,140 L900,220 L0,220 Z"
        fill="url(#fill-sci)"
        stroke="none"
      />
      <!-- Garis ketiga -->
      <path
        class="chart-path"
        d="M0,195 C60,188 120,182 180,175 C240,168 300,160 360,170 C420,180 480,172 540,158 C600,144 660,136 720,145 C780,154 840,148 900,140"
        fill="none"
        stroke="#3A6B7A"
        stroke-width="1"
        stroke-opacity="0.2"
      />

      <!-- Fill area garis kedua -->
      <path
        class="chart-path"
        d="M0,170 C60,158 120,148 180,138 C240,128 300,142 360,132 C420,122 480,108 540,118 C600,128 660,112 720,100 C780,88 840,95 900,88 L900,220 L0,220 Z"
        fill="url(#fill-sci)"
        stroke="none"
      />
      <!-- Garis kedua — accent-sci -->
      <path
        class="chart-path"
        d="M0,170 C60,158 120,148 180,138 C240,128 300,142 360,132 C420,122 480,108 540,118 C600,128 660,112 720,100 C780,88 840,95 900,88"
        fill="none"
        stroke="#3A6B7A"
        stroke-width="1.2"
        stroke-opacity="0.35"
        stroke-dasharray="6 3"
      />

      <!-- Fill area garis utama -->
      <path
        class="chart-path"
        d="M0,145 C60,130 120,118 180,95 C240,72 300,88 360,68 C420,48 480,62 540,45 C600,28 660,40 720,25 C780,10 840,18 900,12 L900,220 L0,220 Z"
        fill="url(#fill-main)"
        stroke="none"
      />

      <!-- Garis utama — accent/burgundy -->
      <path
        class="chart-path chart-main"
        d="M0,145 C60,130 120,118 180,95 C240,72 300,88 360,68 C420,48 480,62 540,45 C600,28 660,40 720,25 C780,10 840,18 900,12"
        fill="none"
        stroke="#6B2D3E"
        stroke-width="1.8"
        stroke-opacity="0.55"
        stroke-linecap="round"
        stroke-linejoin="round"
      />

      <!-- Dots pada titik data garis utama -->
      <circle class="chart-dot" cx="180" cy="95"  r="3" fill="#6B2D3E" fill-opacity="0.7"/>
      <circle class="chart-dot" cx="360" cy="68"  r="3" fill="#6B2D3E" fill-opacity="0.7"/>
      <circle class="chart-dot" cx="540" cy="45"  r="3" fill="#6B2D3E" fill-opacity="0.7"/>
      <circle class="chart-dot" cx="720" cy="25"  r="3" fill="#6B2D3E" fill-opacity="0.7"/>

      <!-- Dot aktif (ujung kanan) dengan pulse -->
      <circle class="dot-pulse-outer" cx="900" cy="12" r="6" fill="#6B2D3E" fill-opacity="0.2"/>
      <circle class="dot-pulse-inner" cx="900" cy="12" r="3" fill="#6B2D3E" fill-opacity="0.85"/>

      <!-- Label sumbu Y — kecil, subtle -->
      <text x="8"  y="52"  class="chart-label">HIGH</text>
      <text x="8"  y="108" class="chart-label">MED</text>
      <text x="8"  y="163" class="chart-label">LOW</text>

      <!-- Label sumbu X -->
      <text x="174" y="215" class="chart-label" text-anchor="middle">Q1</text>
      <text x="354" y="215" class="chart-label" text-anchor="middle">Q2</text>
      <text x="534" y="215" class="chart-label" text-anchor="middle">Q3</text>
      <text x="714" y="215" class="chart-label" text-anchor="middle">Q4</text>

    </g>

    <!-- Overlay fade kiri-kanan — di atas semua konten -->
    <rect x="0" y="0" width="900" height="220" fill="url(#fade-lr)"/>

  </svg>
</div>

<style>
  .chart-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 45%;
    pointer-events: none;
    overflow: hidden;
  }

  .chart-svg {
    width: 100%;
    height: 100%;
  }

  /* Draw animation — clip rect expand dari kiri */
  .reveal-rect {
    animation: chart-draw 2.2s cubic-bezier(0.4, 0, 0.2, 1) 1.2s forwards;
  }
  @keyframes chart-draw {
    from { width: 0; }
    to   { width: 900px; }
  }

  /* Dot pulse pada titik aktif */
  .dot-pulse-outer {
    animation: dot-pulse 2s ease-in-out 3.4s infinite;
  }
  @keyframes dot-pulse {
    0%, 100% { r: 6; fill-opacity: 0.2; }
    50%       { r: 9; fill-opacity: 0.08; }
  }

  /* Label teks */
  .chart-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    fill: #3A3830;
    letter-spacing: 0.06em;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reveal-rect { animation: none; width: 900px; }
    .dot-pulse-outer { animation: none; }
  }
</style>