---
import { getCollection } from 'astro:content';

const { lang = 'id' } = Astro.props;

const allProjects = await getCollection('projects');
const sorted = allProjects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = sorted.find(p => p.data.featured);
const rest     = sorted.filter(p => !p.data.featured).slice(0, 2);

const label  = lang === 'id' ? '/ proyek' : '/ projects';
const ctaAll = lang === 'id' ? 'Lihat semua proyek →' : 'View all projects →';
const ctaOpen = lang === 'id' ? 'Buka proyek' : 'Open project';
const prefix = lang === 'id' ? '/id' : '/en';

const statusColor = (s: string) => {
  if (s === 'Selesai') return '#6A8F6E';
  if (s === 'In Progress' || s === 'Sedang Berjalan') return '#3A6B7A';
  return '#6B2D3E';
};
---

<section class="fp-section" id="projects-preview">
  <div class="glow-fp" aria-hidden="true"></div>
  <div class="fp-wrap">

    <!-- Header -->
    <div class="fp-header">
      <div class="fp-header-left">
        <div class="section-marker">
          <span class="marker-line"></span>
          <p class="marker-label font-mono">{label}</p>
        </div>
        <p class="fp-sub">Eksplorasi data, web, dan segala sesuatu di antaranya.</p>
      </div>
      <a href={`${prefix}/projects`} class="cta-all font-mono">{ctaAll}</a>
    </div>

    <!-- Featured card -->
    {featured && (
      <a href={`${prefix}/projects/${featured.id}`} class="featured-card" aria-label={featured.data.title}>
        <div class="fc-glow" aria-hidden="true"></div>

        <div class="fc-top">
          <div class="fc-labels">
            <span class="fc-category font-mono">{featured.data.category}</span>
            <span class="fc-status font-mono" style={`color:${statusColor(featured.data.status)};border-color:${statusColor(featured.data.status)}40`}>
              {featured.data.status}
            </span>
          </div>
          <span class="fc-featured font-mono">✦ Featured</span>
        </div>

        <h2 class="fc-title">{featured.data.title}</h2>
        <p class="fc-desc">{featured.data.description}</p>

        {featured.data.metric && (
          <div class="fc-metric">
            <span class="metric-bar" aria-hidden="true"></span>
            <span class="metric-text font-mono">{featured.data.metric}</span>
          </div>
        )}

        <div class="fc-bottom">
          <div class="fc-tags">
            {featured.data.tags.slice(0, 5).map((tag: string) => (
              <span class="tag font-mono">{tag}</span>
            ))}
          </div>
          <span class="fc-cta font-mono">{ctaOpen} →</span>
        </div>
      </a>
    )}

    <!-- Rest grid -->
    {rest.length > 0 && (
      <div class="rest-grid">
        {rest.map(project => (
          <a href={`${prefix}/projects/${project.id}`} class="rest-card" aria-label={project.data.title}>
            <div class="rc-top">
              <span class="rc-category font-mono">{project.data.category}</span>
              <span class="rc-status font-mono" style={`color:${statusColor(project.data.status)}`}>
                {project.data.status}
              </span>
            </div>
            <h3 class="rc-title">{project.data.title}</h3>
            <p class="rc-desc">{project.data.description}</p>
            {project.data.metric && (
              <p class="rc-metric font-mono">{project.data.metric}</p>
            )}
            <div class="rc-footer">
              <div class="rc-tags">
                {project.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="tag font-mono">{tag}</span>
                ))}
              </div>
              <span class="rc-cta font-mono">{ctaOpen} →</span>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>
</section>

<style>
/* ── SECTION ─────────────────────────────────────────────── */
.fp-section {
  padding: 7rem 2rem;
  position: relative;
  overflow: hidden;
}
.fp-wrap {
  max-width: 1100px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.glow-fp {
  position: absolute;
  width: 700px; height: 700px;
  border-radius: 50%;
  top: -20%; left: 50%;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(58,107,122,0.1) 0%, transparent 65%);
  filter: blur(80px);
  pointer-events: none; z-index: 0;
}

/* ── HEADER ──────────────────────────────────────────────── */
.fp-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}
.section-marker { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; }
.marker-line { flex: 0 0 28px; height: 1px; background: var(--accent); opacity: 0.5; }
.marker-label { font-size: 0.7rem; color: var(--accent); letter-spacing: 0.18em; text-transform: uppercase; }
.fp-sub { font-size: 0.9rem; color: var(--text-secondary); }
.cta-all {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.3);
  text-decoration: none;
  letter-spacing: 0.08em;
  white-space: nowrap;
  transition: color 200ms;
  padding-bottom: 2px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.cta-all:hover { color: var(--text-primary); border-bottom-color: var(--text-primary); }

/* ── FEATURED CARD ───────────────────────────────────────── */
.featured-card {
  display: block;
  position: relative;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 6px;
  padding: 2rem 2.5rem;
  margin-bottom: 1.25rem;
  text-decoration: none;
  background: rgba(255,255,255,0.015);
  overflow: hidden;
  transition: border-color 250ms, background 250ms, transform 250ms;
}
.featured-card:hover {
  border-color: rgba(107,45,62,0.4);
  background: rgba(107,45,62,0.04);
  transform: translateY(-2px);
}
.fc-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 0% 50%, rgba(107,45,62,0.1) 0%, transparent 60%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 300ms;
}
.featured-card:hover .fc-glow { opacity: 1; }

.fc-top {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
}
.fc-labels { display: flex; align-items: center; gap: 0.6rem; }
.fc-category {
  font-size: 0.65rem; text-transform: uppercase;
  letter-spacing: 0.12em; color: rgba(255,255,255,0.3);
}
.fc-status {
  font-size: 0.6rem; padding: 0.18rem 0.65rem;
  border: 1px solid; border-radius: 2px;
  letter-spacing: 0.06em; text-transform: uppercase;
}
.fc-featured {
  font-size: 0.62rem; color: var(--accent);
  letter-spacing: 0.1em; opacity: 0.7;
}
.fc-title {
  font-family: var(--font-heading), serif;
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 400; color: var(--text-primary);
  line-height: 1.2; margin-bottom: 0.75rem;
}
.fc-desc {
  font-size: 0.92rem; color: var(--text-secondary);
  line-height: 1.7; max-width: 680px; margin-bottom: 1.25rem;
}
.fc-metric {
  display: flex; align-items: center; gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.metric-bar {
  display: block; width: 3px; height: 1.1rem;
  background: var(--accent-data); border-radius: 99px; flex-shrink: 0;
}
.metric-text { font-size: 0.82rem; color: var(--accent-data); }
.fc-bottom {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
}
.fc-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.fc-cta {
  font-size: 0.72rem; color: rgba(255,255,255,0.3);
  letter-spacing: 0.06em;
  transition: color 200ms;
}
.featured-card:hover .fc-cta { color: var(--text-primary); }

/* ── REST GRID ───────────────────────────────────────────── */
.rest-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
.rest-card {
  display: flex; flex-direction: column;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 4px; padding: 1.5rem;
  text-decoration: none;
  background: rgba(255,255,255,0.01);
  transition: border-color 220ms, background 220ms, transform 220ms;
  position: relative; overflow: hidden;
}
.rest-card::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 0% 0%, rgba(58,107,122,0.07) 0%, transparent 60%);
  opacity: 0; transition: opacity 250ms;
}
.rest-card:hover {
  border-color: rgba(58,107,122,0.3);
  background: rgba(58,107,122,0.03);
  transform: translateY(-2px);
}
.rest-card:hover::before { opacity: 1; }

.rc-top {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 0.85rem;
}
.rc-category {
  font-size: 0.62rem; text-transform: uppercase;
  letter-spacing: 0.12em; color: rgba(255,255,255,0.25);
}
.rc-status { font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase; }
.rc-title {
  font-family: var(--font-heading), serif;
  font-size: 1.05rem; font-weight: 400;
  color: var(--text-primary); margin-bottom: 0.5rem; line-height: 1.3;
}
.rc-desc {
  font-size: 0.84rem; color: var(--text-secondary);
  line-height: 1.65; margin-bottom: 0.85rem; flex: 1;
}
.rc-metric {
  font-size: 0.75rem; color: var(--accent-data);
  margin-bottom: 1rem;
}
.rc-footer {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
  margin-top: auto;
}
.rc-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
.rc-cta {
  font-size: 0.68rem; color: rgba(255,255,255,0.25);
  letter-spacing: 0.06em; transition: color 200ms;
}
.rest-card:hover .rc-cta { color: var(--text-primary); }

/* ── SHARED ──────────────────────────────────────────────── */
.tag {
  font-size: 0.62rem; padding: 0.2rem 0.65rem;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 999px; color: rgba(255,255,255,0.3);
  letter-spacing: 0.04em;
}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media (max-width: 700px) {
  .rest-grid { grid-template-columns: 1fr; }
  .featured-card { padding: 1.5rem; }
  .fp-header { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 480px) {
  .fp-section { padding: 5rem 1.25rem; }
}
</style>