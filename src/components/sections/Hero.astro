---
import { getCollection } from 'astro:content';

const { lang = 'id' } = Astro.props;

const t = lang === 'id' ? {
  greeting:     'Halo. Saya Anggara',
  tagline:      'Saya mengubah data yang berantakan menjadi sesuatu yang layak dibaca.',
  cta_projects: 'Lihat Proyek',
  cta_cv:       'Unduh CV',
} : {
  greeting:     "Hello. I'm Anggara",
  tagline:      'I turn messy data into something worth reading.',
  cta_projects: 'View Projects',
  cta_cv:       'Download CV',
};

// Ambil data untuk preview cards
const allProjects = await getCollection('projects');
const featuredProject = allProjects.find(p => p.data.featured) ?? allProjects[0];
const allPosts = await getCollection('blog');
const latestPost = allPosts
  .filter(p => p.data.language === lang)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0];

const sections = lang === 'id'
  ? [
      {
        key: 'about',
        label: '/ Tentang',
        href: `/${lang}/about`,
        preview: 'Mahasiswa SI semester 6, Coding Educator, dan seseorang yang terlalu penasaran dengan data.',
        tag: 'Bio',
      },
      {
        key: 'projects',
        label: '/ Proyek',
        href: `/${lang}/projects`,
        preview: featuredProject?.data.title ?? 'Eksplorasi proyek-proyek data dan web.',
        tag: featuredProject?.data.tags[0] ?? 'ML',
        meta: featuredProject?.data.metric,
      },
      {
        key: 'skills',
        label: '/ Skill',
        href: `/${lang}/skills`,
        preview: 'Python · Pandas · Scikit-learn · SQL · Astro · Next.js',
        tag: 'Tech Stack',
      },
      {
        key: 'experience',
        label: '/ Pengalaman',
        href: `/${lang}/experience`,
        preview: 'Coding Educator di DigiKidz · UNINDRA SI · IPK 3.77',
        tag: '2024 — Sekarang',
      },
      {
        key: 'blog',
        label: '/ Blog',
        href: `/${lang}/blog`,
        preview: latestPost?.data.title ?? 'Catatan dari meja kerja — jujur, bukan konten SEO.',
        tag: latestPost ? `${latestPost.data.readingTime} menit baca` : 'Tulisan',
      },
      {
        key: 'contact',
        label: '/ Kontak',
        href: `/${lang}/contact`,
        preview: 'Terbuka untuk peluang baru — internship, kolaborasi, atau sekadar ngobrol soal data.',
        tag: 'Bekasi, ID',
      },
    ]
  : [
      {
        key: 'about',
        label: '/ About',
        href: `/${lang}/about`,
        preview: 'IS student, Coding Educator, and someone who thinks too much about data.',
        tag: 'Bio',
      },
      {
        key: 'projects',
        label: '/ Projects',
        href: `/${lang}/projects`,
        preview: featuredProject?.data.title ?? 'Data and web projects.',
        tag: featuredProject?.data.tags[0] ?? 'ML',
        meta: featuredProject?.data.metric,
      },
      {
        key: 'skills',
        label: '/ Skills',
        href: `/${lang}/skills`,
        preview: 'Python · Pandas · Scikit-learn · SQL · Astro · Next.js',
        tag: 'Tech Stack',
      },
      {
        key: 'experience',
        label: '/ Experience',
        href: `/${lang}/experience`,
        preview: 'Coding Educator at DigiKidz · UNINDRA IS · GPA 3.77',
        tag: '2024 — Present',
      },
      {
        key: 'blog',
        label: '/ Blog',
        href: `/${lang}/blog`,
        preview: latestPost?.data.title ?? 'Notes from the desk — honest, not SEO content.',
        tag: latestPost ? `${latestPost.data.readingTime} min read` : 'Writing',
      },
      {
        key: 'contact',
        label: '/ Contact',
        href: `/${lang}/contact`,
        preview: 'Open to opportunities — internship, collab, or just talking about data.',
        tag: 'Bekasi, ID',
      },
    ];
---

<section class="hero">
  <!-- Background chart dekoratif -->
  <div class="hero-bg-chart" aria-hidden="true">
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polyline
        points="0,150 80,120 160,140 240,80 320,110 400,60 480,90 560,40 640,70 720,30 800,50"
        fill="none" stroke="#6B2D3E" stroke-width="1.5" stroke-opacity="0.2"
      />
      <polyline
        points="0,180 80,160 160,170 240,130 320,150 400,100 480,130 560,90 640,110 720,70 800,85"
        fill="none" stroke="#3A6B7A" stroke-width="1" stroke-opacity="0.12"
      />
    </svg>
  </div>

  <!-- Hero utama -->
  <div class="hero-content">
    <div class="hero-typed font-mono" id="typed-text" data-text={t.greeting}>
      <span class="prompt">&gt; </span>
      <span id="typed-output"></span>
      <span class="cursor" id="cursor">_</span>
    </div>

    <p class="hero-tagline font-quote" id="hero-tagline">{t.tagline}</p>

    <div class="hero-cta" id="hero-cta">
      <a href={`/${lang}/projects`} class="btn-outline">{t.cta_projects}</a>
      <a href="/cv-anggara.pdf" download="cv-anggara.pdf" class="btn-outline btn-secondary">{t.cta_cv}</a>
    </div>

    <div class="hero-stats" id="hero-stats">
      <div class="stat-chip">
        <span class="stat-value font-mono" data-target="3.77">0</span>
        <span class="stat-label">IPK</span>
      </div>
      <div class="stat-chip">
        <span class="stat-value font-mono" data-target="6">0</span>
        <span class="stat-label">{lang === 'id' ? 'Proyek Selesai' : 'Projects Done'}</span>
      </div>
      <div class="stat-chip">
        <span class="stat-value font-mono" data-target="500">0</span>
        <span class="stat-label">{lang === 'id' ? 'Jam Mengajar' : 'Hours Teaching'}</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" id="scroll-indicator" aria-hidden="true">
    <span class="font-mono" style="font-size: 0.7rem; color: var(--text-secondary)">scroll</span>
    <div class="arrow">↓</div>
  </div>
</section>

<!-- Section preview cards -->
<section class="overview-section">
  <div class="overview-grid">
    {sections.map((s, i) => (
      <a href={s.href} class="overview-card" style={`--delay: ${i * 60}ms`}>
        <div class="card-top">
          <span class="card-label font-mono">{s.label}</span>
          <span class="card-tag font-mono">{s.tag}</span>
        </div>
        <p class="card-preview">{s.preview}</p>
        {s.meta && <p class="card-meta font-mono">{s.meta}</p>}
        <span class="card-arrow">→</span>
      </a>
    ))}
  </div>
</section>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
  }

  .hero-bg-chart {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 40%;
    opacity: 0.6;
    pointer-events: none;
  }
  .hero-bg-chart svg { width: 100%; height: 100%; }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero-typed {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    min-height: 3rem;
  }
  .prompt { color: var(--accent-data); }
  .cursor {
    animation: blink 0.8s step-end infinite;
    color: var(--accent-data);
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    opacity: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0;
  }

  .btn-outline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--accent);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius);
    transition: all 250ms ease;
    letter-spacing: 0.05em;
  }
  .btn-outline:hover {
    background-color: var(--accent);
    box-shadow: 0 0 20px rgba(107, 45, 62, 0.3);
  }
  .btn-secondary { border-color: var(--border); }
  .btn-secondary:hover { background-color: var(--bg-card); box-shadow: none; }

  .hero-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    opacity: 0;
  }
  .stat-chip { display: flex; flex-direction: column; gap: 0.25rem; }
  .stat-value {
    font-size: 1.75rem;
    color: var(--text-primary);
    font-weight: 500;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    opacity: 0;
    animation: fadeInUp 1s ease 4s forwards;
  }
  .arrow {
    color: var(--text-secondary);
    animation: bounce 2s ease infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Overview section ── */
  .overview-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .overview-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    background: var(--bg-card);
    text-decoration: none;
    color: inherit;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 250ms ease;
    opacity: 0;
    transform: translateY(12px);
    animation: cardIn 400ms ease forwards;
    animation-delay: var(--delay);
  }
  /* hilangkan border kanan di kolom terakhir tiap baris */
  .overview-card:nth-child(3n) { border-right: none; }
  /* hilangkan border bawah di baris terakhir */
  .overview-card:nth-last-child(-n+3) { border-bottom: none; }

  .overview-card:hover {
    background: color-mix(in srgb, var(--bg-card) 60%, var(--accent) 8%);
  }
  .overview-card:hover .card-arrow {
    transform: translate(4px, -4px);
    color: var(--accent-data);
  }

  @keyframes cardIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .card-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-data);
  }
  .card-tag {
    font-size: 0.62rem;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .card-preview {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
  }
  .card-meta {
    font-size: 0.72rem;
    color: var(--accent-data);
    opacity: 0.8;
  }
  .card-arrow {
    font-size: 0.85rem;
    color: var(--text-secondary);
    align-self: flex-end;
    transition: transform 200ms ease, color 200ms ease;
  }

  @media (max-width: 768px) {
    .overview-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .overview-card:nth-child(3n) { border-right: 1px solid var(--border); }
    .overview-card:nth-child(2n) { border-right: none; }
    .overview-card:nth-last-child(-n+3) { border-bottom: 1px solid var(--border); }
    .overview-card:nth-last-child(-n+2) { border-bottom: none; }
  }

  @media (max-width: 480px) {
    .overview-grid { grid-template-columns: 1fr; }
    .overview-card { border-right: none !important; }
    .overview-card:not(:last-child) { border-bottom: 1px solid var(--border) !important; }
    .overview-card:last-child { border-bottom: none !important; }
  }
</style>