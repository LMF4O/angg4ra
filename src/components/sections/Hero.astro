---
import { getCollection } from 'astro:content';

const { lang = 'id' } = Astro.props;

const t = lang === 'id' ? {
  greeting:     'Halo. Saya Anggara',
  tagline:      'Membangun sistem, mengolah data dan menyederhanakan teknologi.',
  cta_projects: 'Lihat Proyek',
  cta_cv:       'Unduh CV',
} : {
  greeting:     "Hello. I'm Anggara",
  tagline:      'Building systems, processing data, and simplifying technology.',
  cta_projects: 'View Projects',
  cta_cv:       'Download CV',
};

const sectionIcons = {
  about:      '◈',
  projects:   '◆',
  skills:     '◇',
  experience: '◉',
  blog:       '◐',
  contact:    '◎',
} as const;

// Ambil data untuk preview cards
const allProjects = await getCollection('projects');
const featuredProject = allProjects.find(p => p.data.featured) ?? allProjects[0];
const allPosts = await getCollection('blog');
const latestPost = allPosts
  .filter(p => p.data.language === lang)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0];

const sections = lang === 'id'
  ? [
      {
        key: 'about',
        label: '/ Tentang',
        href: `/${lang}/about`,
        preview: 'Mahasiswa SI semester 6, Coding Educator, dan seseorang yang terlalu penasaran dengan data.',
        tag: 'Bio',
      },
      {
        key: 'projects',
        label: '/ Proyek',
        href: `/${lang}/projects`,
        preview: featuredProject?.data.title ?? 'Eksplorasi proyek-proyek data dan web.',
        tag: featuredProject?.data.tags[0] ?? 'ML',
        meta: featuredProject?.data.metric,
      },
      {
        key: 'skills',
        label: '/ Skill',
        href: `/${lang}/skills`,
        preview: 'Python · Pandas · Scikit-learn · SQL · Astro · Next.js',
        tag: 'Tech Stack',
      },
      {
        key: 'experience',
        label: '/ Pengalaman',
        href: `/${lang}/experience`,
        preview: 'Coding Educator di DigiKidz · UNINDRA SI · IPK 3.77',
        tag: '2024 — Sekarang',
      },
      {
        key: 'blog',
        label: '/ Blog',
        href: `/${lang}/blog`,
        preview: latestPost?.data.title ?? 'Catatan dari meja kerja — jujur, bukan konten SEO.',
        tag: latestPost ? `${latestPost.data.readingTime} menit baca` : 'Tulisan',
      },
      {
        key: 'contact',
        label: '/ Kontak',
        href: `/${lang}/contact`,
        preview: 'Terbuka untuk peluang baru — internship, kolaborasi, atau sekadar ngobrol soal data.',
        tag: 'Bekasi, ID',
      },
    ]
  : [
      {
        key: 'about',
        label: '/ About',
        href: `/${lang}/about`,
        preview: 'IS student, Coding Educator, and someone who thinks too much about data.',
        tag: 'Bio',
      },
      {
        key: 'projects',
        label: '/ Projects',
        href: `/${lang}/projects`,
        preview: featuredProject?.data.title ?? 'Data and web projects.',
        tag: featuredProject?.data.tags[0] ?? 'ML',
        meta: featuredProject?.data.metric,
      },
      {
        key: 'skills',
        label: '/ Skills',
        href: `/${lang}/skills`,
        preview: 'Python · Pandas · Scikit-learn · SQL · Astro · Next.js',
        tag: 'Tech Stack',
      },
      {
        key: 'experience',
        label: '/ Experience',
        href: `/${lang}/experience`,
        preview: 'Coding Educator at DigiKidz · UNINDRA IS · GPA 3.77',
        tag: '2024 — Present',
      },
      {
        key: 'blog',
        label: '/ Blog',
        href: `/${lang}/blog`,
        preview: latestPost?.data.title ?? 'Notes from the desk — honest, not SEO content.',
        tag: latestPost ? `${latestPost.data.readingTime} min read` : 'Writing',
      },
      {
        key: 'contact',
        label: '/ Contact',
        href: `/${lang}/contact`,
        preview: 'Open to opportunities — internship, collab, or just talking about data.',
        tag: 'Bekasi, ID',
      },
    ];
---

<!-- Ambient orbs — outside hero so overflow:hidden doesn't clip them -->
<div class="orb-layer" aria-hidden="true">
  <div class="hero-orb hero-orb--1"></div>
  <div class="hero-orb hero-orb--2"></div>
  <div class="hero-orb hero-orb--3"></div>
</div>

<section class="hero">
  <!-- Background chart dekoratif -->
  <div class="hero-bg-chart" aria-hidden="true">
    <svg viewBox="0 0 800 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <polyline
        points="0,150 80,120 160,140 240,80 320,110 400,60 480,90 560,40 640,70 720,30 800,50"
        fill="none" stroke="#6B2D3E" stroke-width="1.5" stroke-opacity="0.25"
      />
      <polyline
        points="0,180 80,160 160,170 240,130 320,150 400,100 480,130 560,90 640,110 720,70 800,85"
        fill="none" stroke="#3A6B7A" stroke-width="1" stroke-opacity="0.15"
      />
    </svg>
  </div>

  <!-- Hero utama -->
  <div class="hero-content">
    <div class="hero-typed font-mono" id="typed-text" data-text={t.greeting}>
      <span class="prompt">&gt; </span>
      <span id="typed-output"></span>
      <span class="cursor" id="cursor">_</span>
    </div>

    <p class="hero-tagline font-quote" id="hero-tagline">{t.tagline}</p>

    <div class="hero-cta" id="hero-cta">
      <a href={`/${lang}/projects`} class="btn-outline">{t.cta_projects}</a>
      <a href="/cv-anggara.pdf" download="cv-anggara.pdf" class="btn-outline btn-secondary">{t.cta_cv}</a>
    </div>

    <div class="hero-stats" id="hero-stats">
      <div class="stat-chip">
        <span class="stat-value font-mono" data-target="6">0</span>
        <span class="stat-label">{lang === 'id' ? 'Proyek Selesai' : 'Projects Done'}</span>
      </div>
      <div class="stat-chip">
        <span class="stat-value font-mono" data-target="500">0</span>
        <span class="stat-label">{lang === 'id' ? 'Jam Mengajar' : 'Hours Teaching'}</span>
      </div>
    </div>
  </div>

  <!-- Cursor-following orb -->
  <div class="cursor-orb" id="cursor-orb" aria-hidden="true"></div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" id="scroll-indicator" aria-hidden="true">
    <span class="font-mono" style="font-size: 0.7rem; color: var(--text-secondary)">scroll</span>
    <div class="arrow">↓</div>
  </div>
</section>


<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Ambient orbs ── */
  .orb-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(100px);
    opacity: 0;
    animation: orbFadeIn 2.5s ease forwards;
  }
  .hero-orb--1 {
    width: 600px; height: 600px;
    top: -150px; right: -80px;
    background: radial-gradient(circle, rgba(107, 45, 62, 0.22) 0%, transparent 65%);
    animation-delay: 0.4s;
  }
  .hero-orb--2 {
    width: 500px; height: 500px;
    bottom: -80px; left: -100px;
    background: radial-gradient(circle, rgba(58, 107, 122, 0.18) 0%, transparent 65%);
    animation-delay: 0.7s;
  }
  .hero-orb--3 {
    width: 350px; height: 350px;
    top: 35%; right: 20%;
    background: radial-gradient(circle, rgba(107, 45, 62, 0.1) 0%, transparent 65%);
    animation-delay: 1.1s;
  }
  @keyframes orbFadeIn {
    to { opacity: 1; }
  }

  .hero-bg-chart {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 40%;
    opacity: 0.5;
    pointer-events: none;
  }
  .hero-bg-chart svg { width: 100%; height: 100%; }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero-typed {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    min-height: 3rem;
  }
  .prompt { color: var(--accent-data); }
  .cursor {
    animation: blink 0.8s step-end infinite;
    color: var(--accent-data);
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    opacity: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0;
  }

  .btn-outline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--accent);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius);
    transition: all 250ms ease;
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
  }
  .btn-outline::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(107, 45, 62, 0.15), transparent 70%);
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .btn-outline:hover::before { opacity: 1; }
  .btn-outline:hover {
    background-color: var(--accent);
    box-shadow: 0 0 28px rgba(107, 45, 62, 0.35), 0 0 8px rgba(107, 45, 62, 0.2);
  }
  .btn-secondary { border-color: var(--border); }
  .btn-secondary::before { background: none; }
  .btn-secondary:hover { background-color: var(--bg-card); box-shadow: none; }

  .hero-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    opacity: 0;
  }
  .stat-chip {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-value {
    font-size: 1.75rem;
    color: var(--text-primary);
    font-weight: 500;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    opacity: 0;
    animation: fadeInUp 1s ease 4s forwards;
  }
  .arrow {
    color: var(--text-secondary);
    animation: bounce 2s ease infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Overview section ── */
  .overview-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
  }

  .overview-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.5rem 1.5rem 1.25rem;
    background: color-mix(in srgb, var(--bg-card) 75%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: border-color 280ms ease, transform 280ms ease, box-shadow 280ms ease, background 280ms ease;
    opacity: 0;
    transform: translateY(20px);
    animation: cardIn 500ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--delay);
    /* subtle top-inset shimmer */
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .overview-card:hover {
    background: color-mix(in srgb, var(--bg-card) 90%, var(--accent) 6%);
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.18),
      0 0 0 1px color-mix(in srgb, var(--accent) 18%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }
  .overview-card:hover .card-glow { opacity: 1; }
  .overview-card:hover .card-arrow { transform: translateX(3px); }
  .overview-card:hover .card-icon {
    color: var(--accent-data);
    text-shadow: 0 0 10px rgba(107, 45, 62, 0.6);
  }
  .overview-card:hover .card-accent-line { transform: scaleX(1); opacity: 1; }
  .overview-card:hover .card-cta { color: var(--accent-data); }

  /* top accent line — animates in on hover */
  .card-accent-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-data) 100%);
    transform: scaleX(0);
    transform-origin: left;
    opacity: 0;
    transition: transform 350ms cubic-bezier(0.22, 1, 0.36, 1), opacity 350ms ease;
    border-radius: 14px 14px 0 0;
  }

  /* inner glow blob */
  .card-glow {
    position: absolute;
    top: -50px;
    left: -50px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(107, 45, 62, 0.2) 0%, transparent 70%);
    filter: blur(25px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  @keyframes cardIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .card-label-group {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .card-icon {
    font-size: 1rem;
    color: color-mix(in srgb, var(--text-secondary) 70%, var(--accent-data));
    transition: color 250ms ease, text-shadow 250ms ease;
    line-height: 1;
  }

  .card-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-data);
    opacity: 0.9;
  }

  .card-tag {
    font-size: 0.58rem;
    color: color-mix(in srgb, var(--text-secondary) 50%, var(--text-primary));
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
    white-space: nowrap;
    background: color-mix(in srgb, var(--bg-card) 50%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    flex-shrink: 0;
  }

  .card-preview {
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--text-secondary) 40%, var(--text-primary));
    line-height: 1.65;
    flex: 1;
    position: relative;
    z-index: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    font-size: 0.68rem;
    color: var(--accent-data);
    opacity: 0.75;
    position: relative;
    z-index: 1;
    display: block;
    padding: 0.25rem 0.5rem;
    border-left: 2px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border-radius: 0 4px 4px 0;
    letter-spacing: 0.02em;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    position: relative;
    z-index: 1;
    padding-top: 0.25rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
    margin-top: auto;
  }

  .card-cta {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--text-secondary) 30%, var(--text-primary));
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 220ms ease;
    text-transform: uppercase;
  }

  .card-arrow {
    font-size: 0.85rem;
    transition: transform 220ms ease;
    display: inline-block;
  }

  /* ── Cursor orb ── */
  .cursor-orb {
    position: fixed;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(circle, rgba(107, 45, 62, 0.13) 0%, rgba(58, 107, 122, 0.06) 40%, transparent 70%);
    filter: blur(40px);
    transform: translate(-50%, -50%);
    transition: left 0.12s ease-out, top 0.12s ease-out;
    opacity: 0;
    will-change: left, top;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-orb, .overview-card { animation: none; opacity: 1; transform: none; }
    .cursor-orb { display: none; }
  }

  @media (max-width: 768px) {
  }

  @media (max-width: 480px) {
  }
</style>

<script>
  const orb = document.getElementById('cursor-orb') as HTMLElement | null;
  if (orb) {
    let visible = false;
    document.addEventListener('mousemove', (e) => {
      if (!visible) {
        orb.style.opacity = '1';
        visible = true;
      }
      orb.style.left = e.clientX + 'px';
      orb.style.top = e.clientY + 'px';
    });
    document.addEventListener('mouseleave', () => {
      orb.style.opacity = '0';
      visible = false;
    });
  }
</script>