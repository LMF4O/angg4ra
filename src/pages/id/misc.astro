---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import BentoCard from '../../components/ui/BentoCard.astro';
---

<BaseLayout title="Misc" lang="id">
  <div class="page-container">

    <div class="page-header">
      <p class="page-eyebrow font-mono">/ misc</p>
      <h1 class="page-title">Di Luar Kode</h1>
      <p class="page-desc">
        Hal-hal yang membentuk cara saya berpikir — musik, bacaan, dan benang merah dari apa yang sedang saya selidiki secara mendalam.
      </p>
    </div>

    <div class="bento-grid">

      <!-- SPOTIFY CARD -->
      <div class="card-sm">
        <BentoCard size="sm" scanline={true}>
          <div class="spotify-card" id="spotify-widget">
            <p class="section-label font-mono">/ sedang diputar</p>

            <div class="spotify-loading" id="spotify-loading">
              <div class="vinyl-wrapper">
                <div class="vinyl spinning">
                  <div class="vinyl-center"></div>
                </div>
              </div>
              <p class="loading-text font-mono">memuat sinyal...</p>
            </div>

            <div class="spotify-content" id="spotify-content" style="display:none">
              <div class="vinyl-wrapper">
                <div class="vinyl" id="vinyl-disc-playing">
                  <img id="track-art" src="" alt="" class="vinyl-art" />
                  <div class="vinyl-center"></div>
                </div>
              </div>
              <div class="track-info">
                <p class="track-name" id="track-name">—</p>
                <p class="track-artist font-mono" id="track-artist">—</p>
                <div class="track-status font-mono" id="track-status">
                  <span class="dot-live" id="dot-live"></span>
                  <span id="status-text">—</span>
                </div>
              </div>
            </div>

            <div class="spotify-error" id="spotify-error" style="display:none">
              <div class="vinyl-wrapper">
                <div class="vinyl">
                  <div class="vinyl-center"></div>
                </div>
              </div>
              <p class="error-text font-mono">terminal offline.<br/>playlist disembunyikan.</p>
            </div>

            <div class="spotify-footer">
              <a href="https://open.spotify.com/user/gii" target="_blank" rel="noopener" class="spotify-link font-mono">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                Buka di Spotify
              </a>
            </div>
          </div>
        </BentoCard>
      </div>

      <!-- DETECTIVE BOARD -->
      <div class="card-lg">
        <BentoCard size="lg">
          <div class="detective-card">
            <p class="section-label font-mono">/ papan investigasi</p>
            <p class="detective-sub">Benang merah dari anomali data dan teori yang sedang saya bedah.</p>

            <div class="board" id="detective-board">
