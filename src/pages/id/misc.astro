// ── HIGHLIGHT CONNECTED PINS ──────────────────────────────────
function initPinHighlight() {
  const svg = document.getElementById("strings-svg") as unknown as SVGSVGElement | null;
  const allPins = document.querySelectorAll<HTMLElement>(".pin-item");

  allPins.forEach(pin => {
    pin.addEventListener("mouseenter", () => {
      const hoveredId = pin.id;

      // find connected pin IDs
      const connectedIds = new Set<string>();
      CONNECTIONS.forEach(conn => {
        if (conn.from === hoveredId) connectedIds.add(conn.to);
        if (conn.to   === hoveredId) connectedIds.add(conn.from);
      });

      // dim/highlight pins
      allPins.forEach(p => {
        if (p.id === hoveredId) {
          p.style.filter = "brightness(1.3) drop-shadow(0 0 8px rgba(255,255,255,0.25))";
          p.style.zIndex = "10";
        } else if (connectedIds.has(p.id)) {
          p.style.filter = "brightness(1.1) drop-shadow(0 0 6px rgba(255,255,255,0.15))";
          p.style.zIndex = "9";
          p.style.opacity = "1";
        } else {
          p.style.opacity = "0.3";
          p.style.filter  = "none";
        }
      });

      // highlight connected strings, dim others
      if (svg) {
        svg.querySelectorAll("path").forEach((path, i) => {
          const conn = CONNECTIONS[i];
          if (!conn) return;
          if (conn.from === hoveredId || conn.to === hoveredId) {
            path.setAttribute("opacity", "1");
            path.setAttribute("stroke-width", "2");
          } else {
            path.setAttribute("opacity", "0.08");
          }
        });
      }
    });

    pin.addEventListener("mouseleave", () => {
      allPins.forEach(p => {
        p.style.opacity = "";
        p.style.filter  = "";
        p.style.zIndex  = "2";
      });
      if (svg) {
        svg.querySelectorAll("path").forEach((path, i) => {
          const conn = CONNECTIONS[i];
          path.setAttribute("opacity", "0.65");
          path.setAttribute("stroke-width", "1.2");
          if (conn?.dash) path.setAttribute("stroke-dasharray", "4 4");
        });
      }
    });
  });
}

// ── CURSOR GLOW ───────────────────────────────────────────────
function initCursorGlow() {
  const board = document.querySelector<HTMLElement>(".board-wrap");
  const glow  = document.getElementById("board-glow");
  if (!board || !glow) return;

  let glowX = 0, glowY = 0;
  let targetX = 0, targetY = 0;
  let inside = false;
  let raf: number;

  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

  const animate = () => {
    glowX = lerp(glowX, targetX, 0.07);
    glowY = lerp(glowY, targetY, 0.07);
    glow.style.transform = `translate(${glowX}px, ${glowY}px) translate(-50%, -50%)`;
    raf = requestAnimationFrame(animate);
  };

  board.addEventListener("mouseenter", () => {
    inside = true;
    glow.style.opacity = "1";
    raf = requestAnimationFrame(animate);
  });

  board.addEventListener("mouseleave", () => {
    inside = false;
    glow.style.opacity = "0";
    cancelAnimationFrame(raf);
  });

  board.addEventListener("mousemove", (e: MouseEvent) => {
    const rect = board.getBoundingClientRect();
    targetX = e.clientX - rect.left;
    targetY = e.clientY - rect.top;
  });
}

// ── CAT BLINKING ──────────────────────────────────────────────
function initCat() {
  const eyes = document.querySelectorAll<HTMLElement>(".cat-eye");
  if (!eyes.length) return;
  const blink = () => {
    eyes.forEach(e => e.classList.add("cat-blink"));
    setTimeout(() => eyes.forEach(e => e.classList.remove("cat-blink")), 150);
    setTimeout(blink, 2500 + Math.random() * 3000);
  };
  setTimeout(blink, 1500);
}

function initInteractiveCat() {
  const cat = document.getElementById("board-cat");
  const bubble = document.getElementById("cat-bubble");
  const container = document.querySelector(".board-container");
  
  if (!cat || !container) return;

  let isDragging = false;
  let hasMoved = false;
  let startX = 0;
  let origLeft = cat.offsetLeft;
  let purrTimeout;

  // ── FUNGSI TAP / KLIK (Mendengkur & Merubah Ekspresi) ──
  const handleTap = () => {
    // Aktifkan gelembung ucapan
    if (bubble) {
      bubble.style.opacity = "1";
      bubble.style.transform = "translateX(-22%) translateY(-10px) scale(1)";
    }
    
    // Ubah ekspresi mata & beri efek getar mendengkur
    cat.classList.add("cat-happy", "cat-purring");

    // Kembalikan ke normal setelah 2.5 detik
    clearTimeout(purrTimeout);
    purrTimeout = setTimeout(() => {
      if (bubble) {
        bubble.style.opacity = "0";
        bubble.style.transform = "translateX(-22%) translateY(6px) scale(0.94)";
      }
      cat.classList.remove("cat-happy", "cat-purring");
    }, 2500);
  };

  // ── FUNGSI DRAG (Hanya Kanan & Kiri) ──
  const getX = (e) => ("touches" in e ? e.touches[0].clientX : e.clientX);

  const onStart = (e) => {
    if (e instanceof MouseEvent) e.preventDefault();
    isDragging = true;
    hasMoved = false;
    startX = getX(e);
    origLeft = cat.offsetLeft;
    cat.style.transition = "none";
  };

  const onMove = (e) => {
    if (!isDragging) return;
    const currentX = getX(e);
    const dx = currentX - startX;

    // Jika bergeser lebih dari 5 pixel, tandai sebagai aktivitas drag
    if (Math.abs(dx) > 5) hasMoved = true;

    if (!hasMoved) return;

    const containerWidth = container.getBoundingClientRect().width;
    let newLeft = origLeft + dx;

    // Batasi area geser agar tidak keluar layar board (0% sampai ~90%)
    const maxLeft = containerWidth - cat.getBoundingClientRect().width;
    if (newLeft < 0) newLeft = 0;
    if (newLeft > maxLeft) newLeft = maxLeft;

    cat.style.left = `${newLeft}px`;
  };

  const onEnd = () => {
    if (!isDragging) return;
    isDragging = false;
    cat.style.transition = "transform 0.1s ease, left 0.2s ease";

    // Jika cuma ditekan (tidak digeser), picu fungsi mendengkur
    if (!hasMoved) {
      handleTap();
    }
  };

  // Event listener untuk Mouse dan Touch (HP)
  cat.addEventListener("mousedown", onStart);
  cat.addEventListener("touchstart", onStart, { passive: true });
  
  document.addEventListener("mousemove", onMove);
  document.addEventListener("touchmove", onMove, { passive: false });
  
  document.addEventListener("mouseup", onEnd);
  document.addEventListener("touchend", onEnd);
}

// Panggil fungsinya di dalam inisialisasi utama web Anda
document.addEventListener("DOMContentLoaded", () => {
  initInteractiveCat();
});

function drawStrings() {
  const svg = document.getElementById("strings-svg");
  const board = svg?.parentElement;
  if (!svg || !board) return;

  const boardRect = board.getBoundingClientRect();
  svg.setAttribute("viewBox", `0 0 ${boardRect.width} ${boardRect.height}`);
  svg.innerHTML = "";

  CONNECTIONS.forEach(conn => {
    const fromEl = document.getElementById(conn.from);
    const toEl   = document.getElementById(conn.to);
    if (!fromEl || !toEl) return;
    const fromDot = fromEl.querySelector(".pin-head");
    const toDot   = toEl.querySelector(".pin-head");
    if (!fromDot || !toDot) return;

    const fr = fromDot.getBoundingClientRect();
    const tr = toDot.getBoundingClientRect();
    const x1 = fr.left - boardRect.left + fr.width / 2;
    const y1 = fr.top  - boardRect.top  + fr.height / 2;
    const x2 = tr.left - boardRect.left + tr.width / 2;
    const y2 = tr.top  - boardRect.top  + tr.height / 2;
    const mx = (x1 + x2) / 2;
    const my = (y1 + y2) / 2 + 18;

    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    path.setAttribute("d", `M${x1},${y1} Q${mx},${my} ${x2},${y2}`);
    path.setAttribute("fill", "none");
    path.setAttribute("stroke", conn.color);
    path.setAttribute("stroke-width", "1.2");
    path.setAttribute("opacity", "0.65");
    if (conn.dash) path.setAttribute("stroke-dasharray", "4 4");
    svg.appendChild(path);
  });
}

// ── DRAG & DROP ───────────────────────────────────────────────
function initDrag() {
  const board = document.querySelector(".board-wrap") as HTMLElement;
  if (!board) return;

  document.querySelectorAll<HTMLElement>(".pin-item").forEach(pin => {
    let isDragging = false;
    let hasMoved = false;
    let startX = 0, startY = 0;
    let origLeft = 0, origTop = 0;

    const getPos = (e: MouseEvent | TouchEvent) => {
      const t = "touches" in e ? e.touches[0] : e;
      return { x: t.clientX, y: t.clientY };
    };

    const onStart = (e: MouseEvent | TouchEvent) => {
      // Prevent text selection highlight during drag
      if (e instanceof MouseEvent) e.preventDefault();
      isDragging = true;
      hasMoved = false;
      const pos = getPos(e);
      startX = pos.x;
      startY = pos.y;
      origLeft = pin.offsetLeft;
      origTop  = pin.offsetTop;
      pin.style.zIndex = "20";
      pin.style.transition = "none";
      board.style.userSelect = "none";
    };

    const onMove = (e: MouseEvent | TouchEvent) => {
      if (!isDragging) return;
      const pos = getPos(e);
      const dx = pos.x - startX;
      const dy = pos.y - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) hasMoved = true;
      if (!hasMoved) return;
      e.preventDefault();

      const boardRect = board.getBoundingClientRect();
      const newLeft = ((origLeft + dx) / boardRect.width)  * 100;
      const newTop  = ((origTop  + dy) / boardRect.height) * 100;
      pin.style.left = `${Math.max(0, Math.min(95, newLeft))}%`;
      pin.style.top  = `${Math.max(0, Math.min(90, newTop))}%`;
      drawStrings();
    };

    const onEnd = (e: MouseEvent | TouchEvent) => {
      if (!isDragging) return;
      isDragging = false;
      pin.style.transition = "";
      pin.style.zIndex = "2";
      board.style.userSelect = "";
    };

    pin.addEventListener("mousedown",  onStart);
    pin.addEventListener("touchstart", onStart, { passive: true });
    document.addEventListener("mousemove",  onMove);
    document.addEventListener("touchmove",  onMove, { passive: false });
    document.addEventListener("mouseup",    onEnd);
    document.addEventListener("touchend",   onEnd);

    // style as draggable
    pin.style.cursor = "grab";
    pin.querySelector<HTMLElement>(".note")!.style.cursor = "grab";
  });
}

// ── MOBILE BOARD CARDS ────────────────────────────────────────
function isMobile() { return window.innerWidth < 640; }

function renderMobileBoard() {
  const board = document.querySelector(".board-wrap");
  if (!board) return;

  // Already converted
  if (board.classList.contains("board-mobile")) return;
  board.classList.add("board-mobile");

  const cardList = document.createElement("div");
  cardList.className = "mobile-card-list";

  Object.entries(NOTE_DETAILS).forEach(([pinId, data]) => {
    const pinEl = document.getElementById(pinId);
    if (!pinEl) return;
    const pinHead = pinEl.querySelector(".pin-head");
    const pinColor = pinHead?.classList.contains("pin-red")   ? "#8B3A4A"
                   : pinHead?.classList.contains("pin-teal")  ? "#3A7A8B"
                   : "#4A8A5A";

    const card = document.createElement("div");
    card.className = "mobile-card";
    card.innerHTML = `
      <div class="mc-pin" style="background:${pinColor};box-shadow:0 0 7px ${pinColor}88"></div>
      <div class="mc-body">
        <span class="mc-tag font-mono" style="color:${data.tagColor}">${data.tag}</span>
        <p class="mc-title">${data.title}</p>
        <p class="mc-body-text">${data.body}</p>
        ${data.chips ? `<div class="mc-chips">${data.chips.map(c => `<span class="chip font-mono">${c}</span>`).join("")}</div>` : ""}
      </div>`;

    cardList.appendChild(card);
  });

  board.innerHTML = "";
  board.appendChild(cardList);
}

// ── BOOKS ─────────────────────────────────────────────────────
const coverCache: Record<string, string | null> = {};

async function fetchCover(isbn: string): Promise<string | null> {
  if (isbn in coverCache) return coverCache[isbn];
  const url = `https://covers.openlibrary.org/b/isbn/${isbn}-M.jpg?default=false`;
  try {
    const res = await fetch(url);
    coverCache[isbn] = res.ok ? url : null;
  } catch { coverCache[isbn] = null; }
  return coverCache[isbn];
}

const statusLabel = (s: string) =>
  s === "selesai" ? "Selesai Dibaca" : s === "sedang-dibaca" ? "Sedang Dibaca" : "Wishlist";

const statusClass = (s: string) =>
  s === "selesai" ? "bs-done" : s === "sedang-dibaca" ? "bs-reading" : "bs-wish";

let allSpines: HTMLElement[] = [];

async function renderShelf(filter = "semua") {
  const shelf   = document.getElementById("shelf-books")!;
  const loading = document.getElementById("shelf-loading")!;
  const tooltip = document.getElementById("book-tooltip")!;
  const detail  = document.getElementById("detail-panel")!;

  detail.style.display = "none";
  tooltip.style.display = "none";
  shelf.innerHTML = "";
  loading.style.display = "block";
  shelf.appendChild(loading);

  const filtered = filter === "semua"
    ? BOOKS
    : filter === "sedang-dibaca"
      ? BOOKS.filter(b => b.status === "sedang-dibaca")
      : BOOKS.filter(b => b.genre === filter);

  const countEl = document.getElementById("book-count");
  if (countEl) countEl.textContent = BOOKS.length.toString();

  const covers = await Promise.all(filtered.map(b => fetchCover(b.isbn)));
  loading.style.display = "none";
  allSpines = [];

  const mobile = isMobile();

  filtered.forEach((book, i) => {
    const coverUrl = covers[i];
    const spine = document.createElement("div");
    spine.className = "spine";
    // Smaller, consistent heights on mobile
    const h = mobile
      ? Math.floor(95 + Math.random() * 22)
      : Math.floor(130 + Math.random() * 40);
    spine.style.cssText = `--sc:${book.color};--sh:${h}px`;

    spine.innerHTML = `
      <div class="spine-inner">
        ${coverUrl
          ? `<img src="${coverUrl}" alt="${book.title}" class="spine-img" loading="lazy"/>`
          : `<div class="spine-fallback"><span class="spine-char">${book.title[0]}</span></div>`}
        ${book.status === "sedang-dibaca" ? `<div class="reading-dot"></div>` : ""}
      </div>`;

    if (!mobile) {
      spine.addEventListener("mouseenter", e => showTooltip(e as MouseEvent, book.title, book.author));
      spine.addEventListener("mousemove",  e => moveTooltip(e as MouseEvent));
      spine.addEventListener("mouseleave", () => { tooltip.style.display = "none"; });
    }
    spine.addEventListener("click", () => openDetail(book, coverUrl));

    shelf.appendChild(spine);
    allSpines.push(spine);
  });
}

function showTooltip(e: MouseEvent, title: string, author: string) {
  const tooltip = document.getElementById("book-tooltip")!;
  document.getElementById("tt-title")!.textContent  = title;
  document.getElementById("tt-author")!.textContent = author;
  tooltip.style.display = "block";
  moveTooltip(e);
}

function moveTooltip(e: MouseEvent) {
  const tooltip = document.getElementById("book-tooltip")!;
  const x = e.clientX + 14;
  const y = e.clientY - 48;
  tooltip.style.left = `${Math.min(x, window.innerWidth - 240)}px`;
  tooltip.style.top  = `${y}px`;
}

function openDetail(book: typeof BOOKS[0], coverUrl: string | null) {
  const panel = document.getElementById("detail-panel")!;

  document.getElementById("detail-genre")!.textContent  = book.genre.toUpperCase();
  document.getElementById("detail-title")!.textContent  = book.title;
  document.getElementById("detail-author")!.textContent = book.author;
  document.getElementById("detail-year")!.textContent   = book.year;
  document.getElementById("detail-note")!.textContent   = book.note;

  const badge = document.getElementById("detail-status-badge")!;
  badge.textContent  = statusLabel(book.status);
  badge.className    = `detail-status font-mono ${statusClass(book.status)}`;

  const img      = document.getElementById("detail-img") as HTMLImageElement;
  const fallback = document.getElementById("detail-fallback")!;
  const fallChar = document.getElementById("detail-fallback-char")!;

  if (coverUrl) {
    img.src = coverUrl;
    img.style.display = "block";
    fallback.style.display = "none";
  } else {
    img.style.display = "none";
    fallback.style.display = "flex";
    fallback.style.background = book.color;
    fallChar.textContent = book.title[0];
  }

  panel.style.display = "block";
  panel.scrollIntoView({ behavior: "smooth", block: "nearest" });
}

// ── INIT ──────────────────────────────────────────────────────
function init() {
  if (isMobile()) {
    renderMobileBoard();
  } else {
    drawStrings();
    window.addEventListener("resize", () => {
      drawStrings();
    });
    initDrag();
    initPinHighlight();
    initCursorGlow();
  }
  initCat();

  // filter tabs
  document.querySelectorAll(".ftab").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".ftab").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      renderShelf((btn as HTMLElement).dataset.filter || "semua");
    });
  });

  // close detail
  document.getElementById("detail-back")?.addEventListener("click", () => {
    document.getElementById("detail-panel")!.style.display = "none";
  });

  renderShelf();
}

document.addEventListener("astro:page-load", init);
document.addEventListener("DOMContentLoaded", init);
</script>

