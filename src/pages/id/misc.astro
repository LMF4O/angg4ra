// === SPOTIFY ===
const SPOTIFY_CONFIG = {
  CLIENT_ID: '0eaa7f17c9b044cabbb1dc54ad3b1af7',
  CLIENT_SECRET: 'GANTI_DENGAN_CLIENT_SECRET',
  REFRESH_TOKEN: 'GANTI_DENGAN_REFRESH_TOKEN',
};

async function fetchSpotify() {
  const loading = document.getElementById('spotify-loading');
  const content = document.getElementById('spotify-content');
  const error   = document.getElementById('spotify-error');

  const isDummy = SPOTIFY_CONFIG.REFRESH_TOKEN === 'GANTI_DENGAN_REFRESH_TOKEN'
               || SPOTIFY_CONFIG.CLIENT_SECRET === 'GANTI_DENGAN_CLIENT_SECRET';

  if (isDummy) {
    showSpotifyContent({
      name: 'Acoustic & Lo-Fi Session',
      artist: 'Ambient Collector',
      albumArt: null,
      isPlaying: false,
      statusText: 'terakhir diputar',
    });
    return;
  }

  try {
    const tokenRes = await fetch('https://accounts.spotify.com/api/token', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Authorization': 'Basic ' + btoa(SPOTIFY_CONFIG.CLIENT_ID + ':' + SPOTIFY_CONFIG.CLIENT_SECRET),
      },
      body: new URLSearchParams({
        grant_type: 'refresh_token',
        refresh_token: SPOTIFY_CONFIG.REFRESH_TOKEN,
      }),
    });
    const { access_token } = await tokenRes.json();

    const nowRes = await fetch('https://api.spotify.com/v1/me/player/currently-playing', {
      headers: { 'Authorization': `Bearer ${access_token}` },
    });

    if (nowRes.status === 200) {
      const data = await nowRes.json();
      if (data && data.item) {
        showSpotifyContent({
          name: data.item.name,
          artist: data.item.artists.map((a: any) => a.name).join(', '),
          albumArt: data.item.album.images[0]?.url || null,
          isPlaying: data.is_playing,
          statusText: data.is_playing ? 'sedang diputar' : 'dijeda',
        });
        return;
      }
    }

    const recentRes = await fetch('https://api.spotify.com/v1/me/player/recently-played?limit=1', {
      headers: { 'Authorization': `Bearer ${access_token}` },
    });
    const recentData = await recentRes.json();
    const track = recentData.items?.[0]?.track;
    if (track) {
      showSpotifyContent({
        name: track.name,
        artist: track.artists.map((a: any) => a.name).join(', '),
        albumArt: track.album.images[0]?.url || null,
        isPlaying: false,
        statusText: 'terakhir diputar',
      });
    } else {
      showError();
    }
  } catch (e) {
    showError();
  }

  function showSpotifyContent({ name, artist, albumArt, isPlaying, statusText }: any) {
    if (!loading || !content) return;
    loading.style.display = 'none';
    content.style.display = 'block';

    const tn = document.getElementById('track-name');
    const ta = document.getElementById('track-artist');
    const st = document.getElementById('status-text');
    if (tn) tn.textContent = name;
    if (ta) ta.textContent = artist;
    if (st) st.textContent = statusText;

    const dotLive = document.getElementById('dot-live');
    if (dotLive) {
      isPlaying ? dotLive.classList.add('live') : dotLive.classList.remove('live');
    }

    const vinyl = document.getElementById('vinyl-disc-playing');
    if (vinyl) {
      isPlaying ? vinyl.classList.add('spinning') : vinyl.classList.remove('spinning');
    }

    if (albumArt) {
      const img = document.getElementById('track-art') as HTMLImageElement;
      if (img) { img.src = albumArt; img.style.display = 'block'; }
    }
  }

  function showError() {
    if (loading) loading.style.display = 'none';
    if (error) error.style.display = 'block';
  }
}

// === DETECTIVE BOARD: BENANG MERAH ===
function initDetectiveStrings() {
  const board = document.getElementById('detective-board');
  const svg = document.getElementById('string-svg') as unknown as SVGElement;
  if (!board || !svg) return;

  const pins = board.querySelectorAll('.pin');
  const pinPositions: { cx: number; cy: number }[] = [];

  pins.forEach(pin => {
    const el = pin as HTMLElement;
    const rect = el.getBoundingClientRect();
    const boardRect = board.getBoundingClientRect();
    pinPositions.push({
      cx: rect.left - boardRect.left + rect.width / 2,
      cy: rect.top - boardRect.top + rect.height / 2,
    });
  });

  // Update SVG lines berdasarkan posisi pin nyata
  const lines = svg.querySelectorAll('line');
  const connections = [
    [0, 1], // ISPU → Proposal
    [1, 2], // Proposal → Website
    [2, 3], // Website → Identitas
    [1, 4], // Proposal → MLOps
    [2, 5], // Website → Lua
  ];

  lines.forEach((line, i) => {
    const conn = connections[i];
    if (!conn || !pinPositions[conn[0]] || !pinPositions[conn[1]]) return;
    const a = pinPositions[conn[0]];
    const b = pinPositions[conn[1]];
    line.setAttribute('x1', String(a.cx));
    line.setAttribute('y1', String(a.cy));
    line.setAttribute('x2', String(b.cx));
    line.setAttribute('y2', String(b.cy));
  });
}

// === BOOKSHELF ===
const coverCache: Record<string, string | null> = {};

async function fetchCover(isbn: string) {
  if (coverCache[isbn] !== undefined) return coverCache[isbn];
  const url = `https://covers.openlibrary.org/b/isbn/${isbn}-M.jpg?default=false`;
  try {
    const res = await fetch(url);
    if (res.ok) { coverCache[isbn] = url; return url; }
  } catch {}
  coverCache[isbn] = null;
  return null;
}

function statusLabel(s: string) {
  if (s === 'selesai') return 'Selesai Dibaca';
  if (s === 'sedang-dibaca') return 'Sedang Dibaca';
  return 'Wishlist';
}

function statusClass(s: string) {
  if (s === 'selesai') return 'bs-done';
  if (s === 'sedang-dibaca') return 'bs-reading';
  return 'bs-wish';
}

async function renderBooks(filter = 'semua') {
  const shelf = document.getElementById('bookshelf');
  const loading = document.getElementById('shelf-loading');
  if (!shelf || !loading) return;

  const filtered = filter === 'semua'
    ? BOOKS
    : filter === 'sedang-dibaca'
      ? BOOKS.filter(b => b.status === 'sedang-dibaca')
      : BOOKS.filter(b => b.genre === filter);

  const countEl = document.getElementById('book-count');
  if (countEl) countEl.textContent = BOOKS.length.toString();

  loading.style.display = 'block';
  shelf.innerHTML = '';
  shelf.appendChild(loading);

  const fragment = document.createDocumentFragment();

  await Promise.all(filtered.map(async (book, i) => {
    const coverUrl = await fetchCover(book.isbn);
    const spine = document.createElement('div');
    spine.className = 'book-spine';
    spine.dataset.index = i.toString();
    spine.style.setProperty('--spine-color', book.color || '#333');
    spine.setAttribute('title', book.title);

    // Hanya tampilkan cover saja, tanpa nama
    spine.innerHTML = `
      <div class="spine-inner">
        ${coverUrl
          ? `<img src="${coverUrl}" alt="${book.title}" class="spine-cover" loading="lazy" />`
          : `<div class="spine-fallback" style="background:${book.color || '#333'}">
               <span class="spine-initial">${book.title.charAt(0)}</span>
             </div>`
        }
        ${book.status === 'sedang-dibaca' ? '<div class="spine-reading-dot"></div>' : ''}
      </div>
    `;

    // Hover tooltip
    const tooltip = document.getElementById('book-tooltip');
    const ttTitle = document.getElementById('tt-title');
    const ttAuthor = document.getElementById('tt-author');

    spine.addEventListener('mouseenter', (e) => {
      if (tooltip && ttTitle && ttAuthor) {
        ttTitle.textContent = book.title;
        ttAuthor.textContent = book.author;
        tooltip.style.display = 'block';
        positionTooltip(e as MouseEvent, tooltip);
      }
    });
    spine.addEventListener('mousemove', (e) => {
      if (tooltip) positionTooltip(e as MouseEvent, tooltip);
    });
    spine.addEventListener('mouseleave', () => {
      if (tooltip) tooltip.style.display = 'none';
    });

    spine.addEventListener('click', () => {
      if (tooltip) tooltip.style.display = 'none';
      openDetail(book, coverUrl);
    });
    fragment.appendChild(spine);
  }));

  loading.style.display = 'none';
  shelf.appendChild(fragment);
}

function positionTooltip(e: MouseEvent, tooltip: HTMLElement) {
  const x = e.clientX + 14;
  const y = e.clientY - 36;
  tooltip.style.left = x + 'px';
  tooltip.style.top  = y + 'px';
}

function openDetail(book: any, coverUrl: string | null) {
  const panel = document.getElementById('book-detail');
  const shelf = document.getElementById('bookshelf');
  const filters = document.getElementById('book-filters');
  if (!panel || !shelf || !filters) return;

  const dg = document.getElementById('detail-genre');
  const dt = document.getElementById('detail-title');
  const da = document.getElementById('detail-author');
  const dy = document.getElementById('detail-year');
  const dn = document.getElementById('detail-note');
  const ds = document.getElementById('detail-status');

  if (dg) dg.textContent = book.genre.toUpperCase();
  if (dt) dt.textContent = book.title;
  if (da) da.textContent = 'oleh ' + book.author;
  if (dy) dy.textContent = `${book.year}`;
  if (dn) dn.textContent = book.note || '';
  if (ds) {
    ds.textContent = statusLabel(book.status);
    ds.className = 'detail-status font-mono ' + statusClass(book.status);
  }

  const img = document.getElementById('detail-cover') as HTMLImageElement;
  const fallback = document.getElementById('detail-cover-fallback');
  const initial = document.getElementById('detail-cover-initial');
  if (img && fallback) {
    if (coverUrl) {
      img.src = coverUrl;
      img.style.display = 'block';
      fallback.style.display = 'none';
    } else {
      img.style.display = 'none';
      fallback.style.display = 'flex';
      fallback.style.background = book.color || '#333';
      if (initial) initial.textContent = book.title.charAt(0);
    }
  }

  shelf.style.display = 'none';
  filters.style.display = 'none';
  panel.style.display = 'block';
  panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function closeDetail() {
  const panel = document.getElementById('book-detail');
  const shelf = document.getElementById('bookshelf');
  const filters = document.getElementById('book-filters');
  if (panel && shelf && filters) {
    panel.style.display = 'none';
    shelf.style.display = 'flex';
    filters.style.display = 'flex';
  }
}

function setupEventListeners() {
  document.getElementById('detail-close')?.addEventListener('click', closeDetail);

  document.querySelectorAll('.bfilter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.bfilter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLButtonElement).dataset.filter;
      renderBooks(filter);
      closeDetail();
    });
  });
}

function init() {
  fetchSpotify();
  renderBooks().then(() => {
    // Tunggu render selesai lalu init benang
    setTimeout(initDetectiveStrings, 100);
  });
  setupEventListeners();

  // Re-init benang pas resize
  window.addEventListener('resize', initDetectiveStrings);
}

document.addEventListener('astro:page-load', init);
document.addEventListener('DOMContentLoaded', init);
</script>

