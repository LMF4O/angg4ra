              <div class="pin" style="top:55%; left:22%;">
                <div class="pin-dot pin-green"></div>
                <div class="note note-small note-yellow note-hover">
                  <p class="note-label font-mono">LOG</p>
                  <p class="note-title">Lua & Roblox Dev</p>
                  <p class="note-body">Virtual environment design berbasis objek sejak SMA.</p>
                </div>
              </div>

              <div class="polaroid" style="top:18%; left:44%; transform:rotate(3deg)">
                <div class="polaroid-img">📊</div>
                <p class="polaroid-caption font-mono">METRIK_ISPU</p>
              </div>

              <div class="polaroid" style="top:50%; left:52%; transform:rotate(-4deg)">
                <div class="polaroid-img">🎸</div>
                <p class="polaroid-caption font-mono">HP_VICTUS_26</p>
              </div>

              <!-- Sticky note lokasi -->
              <div class="sticky sticky-teal" style="bottom:5%; right:4%; transform:rotate(1deg)">
                <p class="font-mono sticky-text">Bekasi, ID 📍</p>
              </div>

              <!-- Sticky note tambahan -->
              <div class="sticky sticky-red" style="bottom:5%; left:42%; transform:rotate(-2deg)">
                <p class="font-mono sticky-text">67 = jawaban?</p>
              </div>
            </div>
          </div>
        </BentoCard>
      </div>

      <!-- BOOKSHELF -->
      <div class="card-xl">
        <BentoCard size="xl">
          <div class="library-card">
            <div class="library-header">
              <div>
                <p class="section-label font-mono">/ arsip perpustakaan</p>
                <p class="library-sub">Katalog literatur yang memengaruhi pola pikir ilmiah dan naratif saya.</p>
              </div>
              <div class="library-meta font-mono">
                <span id="book-count">—</span> judul terdaftar
              </div>
            </div>

            <div class="book-filters" id="book-filters">
              <button class="bfilter active font-mono" data-filter="semua">Semua</button>
              <button class="bfilter font-mono" data-filter="fiksi">Fiksi</button>
              <button class="bfilter font-mono" data-filter="nonfiksi">Non-fiksi</button>
              <button class="bfilter font-mono" data-filter="teknis">Teknis</button>
              <button class="bfilter font-mono" data-filter="sedang-dibaca">Sedang Dipelajari</button>
            </div>

            <!-- VISUAL BOOKSHELF RAK -->
            <div class="shelf-visual" id="bookshelf">
              <div class="shelf-loading font-mono" id="shelf-loading">membuka enkripsi arsip...</div>
            </div>

            <!-- TOOLTIP hover -->
            <div class="book-tooltip" id="book-tooltip" style="display:none">
              <p class="tooltip-title font-mono" id="tt-title">—</p>
              <p class="tooltip-author font-mono" id="tt-author">—</p>
            </div>

            <!-- DETAIL PANEL -->
            <div class="book-detail" id="book-detail" style="display:none">
              <button class="detail-close font-mono" id="detail-close">← kembali ke rak</button>
              <div class="detail-inner">
                <div class="detail-cover-container">
                  <img id="detail-cover" src="" alt="" class="detail-cover" />
                  <div class="detail-cover-fallback" id="detail-cover-fallback" style="display:none">
                    <span id="detail-cover-initial">?</span>
                  </div>
                </div>
                <div class="detail-info">
                  <p class="detail-genre font-mono" id="detail-genre">—</p>
                  <h3 class="detail-title" id="detail-title">—</h3>
                  <p class="detail-author font-mono" id="detail-author">—</p>
                  <p class="detail-year font-mono" id="detail-year">—</p>
                  <div class="detail-divider"></div>
                  <p class="detail-note" id="detail-note">—</p>
                  <span class="detail-status font-mono" id="detail-status">—</span>
                </div>
