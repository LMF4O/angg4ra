---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import BentoCard from '../../components/ui/BentoCard.astro';

const experiences = [
  {
    role: 'Coding Educator',
    company: 'PT DigiKidz Indonesia',
    location: 'Cibubur, Jakarta Timur',
    period: 'Jan 2024 — Sekarang',
    type: 'Part-time',
    color: 'var(--accent-data)',
    points: [
      'Mengajar pemrograman dan computational thinking ke anak-anak usia 7–15 tahun.',
      'Menyusun laporan pembelajaran terstruktur per sesi untuk setiap murid.',
      'Mengadaptasi materi ajar sesuai level pemahaman tiap anak secara individual.',
      'Memperkenalkan konsep algoritma dan logika lewat game dan proyek kecil.',
    ],
  },
];

const education = [
  {
    degree: 'S1 Sistem Informasi',
    institution: 'Universitas Indraprasta PGRI (UNINDRA)',
    period: '2023 — Sekarang',
    gpa: '3.77',
    color: 'var(--accent-sci)',
    highlights: [
      'Semester 6 — target lulus 2026',
      'Fokus: Machine Learning, Basis Data, Rekayasa Perangkat Lunak',
      'Tugas akhir: Sistem Manajemen Informasi DigiKidz dengan prediksi performa siswa berbasis ML',
    ],
  },
];

const certifications = [
  { name: 'Belajar Machine Learning untuk Pemula', issuer: 'Dicoding', year: '2024' },
  { name: 'Python for Data Science', issuer: 'Kaggle', year: '2024' },
  { name: 'SQL for Data Analysis', issuer: 'Kaggle', year: '2024' },
];
---

<BaseLayout title="Pengalaman" lang="id">
  <div class="page-container">
    <h1 class="page-title">Pengalaman</h1>
    <p class="page-desc">Perjalanan profesional dan akademis yang membentuk cara saya bekerja.</p>

    <div class="bento-grid">

      <!-- Timeline Pengalaman Kerja -->
      <div class="card-xl">
        <BentoCard size="xl">
          <p class="section-label font-mono">/ pengalaman kerja</p>

          <div class="timeline">
            {experiences.map((exp, i) => (
              <div class="timeline-entry">
                <div class="timeline-dot" style={`background: ${exp.color}`}></div>
                {i < experiences.length - 1 && <div class="timeline-line"></div>}

                <div class="timeline-body">
                  <div class="timeline-header">
                    <div>
                      <h2 class="exp-role">{exp.role}</h2>
                      <p class="exp-company">{exp.company}</p>
                      <p class="exp-location font-mono">{exp.location}</p>
                    </div>
                    <div class="timeline-meta">
                      <span class="exp-period font-mono">{exp.period}</span>
                      <span class="exp-type font-mono" style={`color: ${exp.color}`}>{exp.type}</span>
                    </div>
                  </div>

                  <ul class="exp-points">
                    {exp.points.map(point => (
                      <li>{point}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}

            <!-- Open to work indicator -->
            <div class="timeline-entry open-entry">
              <div class="timeline-dot pulsing" style="background: var(--accent-data)"></div>
              <div class="timeline-body">
                <p class="font-mono open-label">terbuka untuk peluang baru</p>
              </div>
            </div>
          </div>
        </BentoCard>
      </div>

      <!-- Pendidikan -->
      <div class="card-lg">
        <BentoCard size="lg">
          <p class="section-label font-mono">/ pendidikan</p>

          <div class="edu-list">
            {education.map(edu => (
              <div class="edu-entry">
                <div class="edu-left">
                  <div class="edu-dot" style={`background: ${edu.color}`}></div>
                </div>
                <div class="edu-right">
                  <div class="edu-header">
                    <div>
                      <h3 class="edu-degree">{edu.degree}</h3>
                      <p class="edu-institution">{edu.institution}</p>
                    </div>
                    <div class="edu-meta">
                      <span class="edu-period font-mono">{edu.period}</span>
                      <span class="edu-gpa font-mono" style={`color: ${edu.color}`}>IPK {edu.gpa}</span>
                    </div>
                  </div>
                  <ul class="edu-highlights">
                    {edu.highlights.map(h => (
                      <li>{h}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </BentoCard>
      </div>

      <!-- Sertifikasi -->
      <div class="card-sm">
        <BentoCard size="sm">
          <p class="section-label font-mono">/ sertifikasi</p>
          <div class="cert-list">
            {certifications.map(cert => (
              <div class="cert-item">
                <span class="cert-name">{cert.name}</span>
                <div class="cert-meta">
                  <span class="cert-issuer font-mono">{cert.issuer}</span>
                  <span class="cert-year font-mono">{cert.year}</span>
                </div>
              </div>
            ))}
          </div>
        </BentoCard>
      </div>

      <!-- Stats ringkas -->
      <div class="card-xl">
        <BentoCard size="xl">
          <div class="stats-row">
            {[
              { value: '1+', label: 'Tahun Mengajar', color: 'var(--accent-data)' },
              { value: '3.77', label: 'IPK Saat Ini', color: 'var(--accent-sci)' },
              { value: '500+', label: 'Jam Mengajar', color: 'var(--accent)' },
              { value: '6+', label: 'Proyek Selesai', color: 'var(--accent-data)' },
            ].map(stat => (
              <div class="stat-block">
                <span class="stat-val font-mono" style={`color: ${stat.color}`}>{stat.value}</span>
                <span class="stat-lbl font-mono">{stat.label}</span>
              </div>
            ))}
          </div>
        </BentoCard>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .page-title {
    font-family: var(--font-heading);
    margin-bottom: 0.75rem;
  }
  .page-desc {
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 480px;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
  }
  .card-xl  { grid-column: span 12; }
  .card-lg  { grid-column: span 9; }
  .card-sm  { grid-column: span 3; }

  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .timeline-entry {
    display: flex;
    gap: 1.25rem;
    position: relative;
  }
  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.4rem;
  }
  .timeline-dot.pulsing {
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(106,143,110,0.4); }
    50% { opacity: 0.8; box-shadow: 0 0 0 6px rgba(106,143,110,0); }
  }
  .timeline-line {
    position: absolute;
    left: 4px;
    top: 16px;
    bottom: -1.5rem;
    width: 1px;
    background: var(--border);
  }
  .timeline-body {
    flex: 1;
    padding-bottom: 2.5rem;
  }
  .open-entry .timeline-body {
    padding-bottom: 0;
  }
  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .exp-role {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .exp-company {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.1rem;
  }
  .exp-location {
    font-size: 0.7rem;
    color: var(--text-secondary);
    opacity: 0.6;
  }
  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    flex-shrink: 0;
  }
  .exp-period {
    font-size: 0.72rem;
    color: var(--text-secondary);
  }
  .exp-type {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .exp-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0;
  }
  .exp-points li {
    font-size: 0.9rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }
  .exp-points li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--border);
  }
  .open-label {
    font-size: 0.72rem;
    color: var(--accent-data);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0;
  }

  /* Pendidikan */
  .edu-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .edu-entry { display: flex; gap: 1rem; }
  .edu-left { padding-top: 0.35rem; }
  .edu-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .edu-right { flex: 1; }
  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .edu-degree { font-size: 1rem; margin-bottom: 0.2rem; }
  .edu-institution { font-size: 0.85rem; color: var(--text-secondary); }
  .edu-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .edu-period { font-size: 0.7rem; color: var(--text-secondary); }
  .edu-gpa { font-size: 0.75rem; }
  .edu-highlights {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .edu-highlights li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
  }
  .edu-highlights li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent-sci);
  }

  /* Sertifikasi */
  .cert-list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .cert-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cert-item:last-child { border-bottom: none; padding-bottom: 0; }
  .cert-name { font-size: 0.85rem; color: var(--text-primary); line-height: 1.4; }
  .cert-meta { display: flex; justify-content: space-between; }
  .cert-issuer { font-size: 0.7rem; color: var(--accent-data); }
  .cert-year { font-size: 0.7rem; color: var(--text-secondary); }

  /* Stats row */
  .stats-row {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding: 0.5rem 0;
  }
  .stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .stat-val {
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
  }
  .stat-lbl {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .card-xl, .card-lg, .card-sm { grid-column: span 12; }
    .timeline-header, .edu-header { flex-direction: column; gap: 0.5rem; }
    .timeline-meta, .edu-meta { align-items: flex-start; }
  }
</style>