const education = [
  {
    degree: 'S1 Sistem Informasi',
    institution: 'Universitas Indraprasta PGRI (UNINDRA)',
    period: '2023 - Sekarang',
    gpa: '3.77',
    color: '#3A6B7A',
    highlights: [
      'Semester 6 — target lulus 2026',
      'Fokus: Machine Learning, Basis Data, Rekayasa Perangkat Lunak',
      'Skripsi: CRM + prediksi performa siswa berbasis ML untuk DigiKidz',
    ],
  },
  {
    degree: 'SMK - Rekayasa Perangkat Lunak',
    institution: 'SMK Negeri 24 Jakarta',
    period: '2020 — 2023',
    gpa: null,
    color: '#6A8F6E',
    highlights: [
      'Jurusan Rekayasa Perangkat Lunak',
      'Dasar pemrograman, basis data, dan pengembangan aplikasi',
    ],
  },
