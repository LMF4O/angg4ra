---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import BentoCard from '../../components/ui/BentoCard.astro';
import FeaturedProjects from '../../components/sections/FeaturedProjects.astro';

const skillCategories = [
  {
    id: 'data', category: 'Data & Analytics', color: 'var(--accent-data)', hex: '6A8F6E',
    icons: [
      { name: 'Python',      slug: 'python' },
      { name: 'Pandas',      slug: 'pandas' },
      { name: 'Scikit-learn',slug: 'scikitlearn' },
      { name: 'NumPy',       slug: 'numpy' },
      { name: 'Jupyter',     slug: 'jupyter' },
      { name: 'Kaggle',      slug: 'kaggle' },
    ],
    extra: ['SHAP', 'Matplotlib', 'Seaborn', 'SQL'],
  },
  {
    id: 'web', category: 'Web Development', color: 'var(--accent-sci)', hex: '3A6B7A',
    icons: [
      { name: 'JavaScript',  slug: 'javascript' },
      { name: 'TypeScript',  slug: 'typescript' },
      { name: 'Astro',       slug: 'astro' },
      { name: 'Next.js',     slug: 'nextdotjs' },
      { name: 'React',       slug: 'react' },
      { name: 'Tailwind',    slug: 'tailwindcss' },
    ],
    extra: ['Framer Motion', 'HTML & CSS', 'Vite'],
  },
  {
    id: 'tools', category: 'Tools & Lainnya', color: 'var(--accent)', hex: '6B2D3E',
    icons: [
      { name: 'Git',         slug: 'git' },
      { name: 'GitHub',      slug: 'github' },
      { name: 'Figma',       slug: 'figma' },
      { name: 'VS Code',     slug: 'v' },
      { name: 'FastAPI',     slug: 'fastapi' },
      { name: 'SQLite',      slug: 'sqlite' },
      { name: 'Counter Strike', slug: 'counterstrike' },
      { name: 'Valorant',    slug: 'valorant' },
      { name: 'Duolingo',    slug: 'duolingo' },
    ],
    extra: ['Excel', 'Java Swing', 'Roblox Studio', 'Lua'],
  },
];

const experiences = [
  {
    role: 'Coding Educator',
    company: 'PT DigiKidz Indonesia',
    location: 'Cibubur, Jakarta Timur',
    period: 'Jan 2024 — Sekarang',
    type: 'Part-time',
    color: '#6A8F6E',
    points: [
      'Mengajar pemrograman dan computational thinking ke anak-anak usia 7–15 tahun.',
      'Menyusun laporan pembelajaran terstruktur per sesi untuk setiap murid.',
      'Mengadaptasi materi ajar sesuai level pemahaman tiap anak secara individual.',
      'Memperkenalkan konsep algoritma dan logika lewat game dan proyek kecil.',
    ],
  },
  {
    role: 'Freelance Web Developer',
    company: 'Independent',
    location: 'Remote',
    period: '2023 — 2024',
    type: 'Freelance',
    color: '#3A6B7A',
    points: [
      'Membangun website profil dan portofolio untuk klien individu.',
      'Mengerjakan landing page dengan HTML, CSS, dan JavaScript vanilla.',
      'Berkoordinasi langsung dengan klien untuk kebutuhan desain dan konten.',
    ],
  },
  {
    role: 'Hak Paten Software',
    company: 'Desa Ciherang',
    location: 'Indonesia',
    period: '2025',
    type: 'Achievement',
    color: '#6B2D3E',
    points: [
      'Mendaftarkan karya cipta software website desa wisata (EC00202500538).',
      'Proyek dikembangkan sebagai solusi promosi digital untuk desa wisata lokal.',
    ],
  },
  {
    role: 'Back-end Developer',
    company: 'SMK Negeri 24 Jakarta',
    location: '',
    period: '2022',
    type: 'Part-time',
    color: '#7A6B3A',
    points: [
      'Membantu pembuatan Website LSP untuk Sekolah.',
      'Membuat api dan merapihkan alur logika back-end.',
    ],
  },
