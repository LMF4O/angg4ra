---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => post.data.language === 'en')
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, tags, readingTime, excerpt } = post.data;
---

<BaseLayout title={title} lang="en">
  <div class="page-container">

    <a href="/en/blog" class="back-link font-mono">← Back to Blog</a>

    <header class="post-header">
      <div class="post-meta font-mono">
        <span>{date}</span>
        <span class="separator">·</span>
        <span>{readingTime} min read</span>
      </div>
      <h1>{title}</h1>
      <p class="post-excerpt">{excerpt}</p>
      <div class="tags">
        {tags.map(tag => <span class="tag font-mono">{tag}</span>)}
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .back-link {
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: inline-block;
    margin-bottom: 2.5rem;
    transition: color 200ms ease;
  }
  .back-link:hover { color: var(--text-primary); }
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .post-meta {
    font-size: 0.72rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .separator { opacity: 0.4; }
  .post-excerpt {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }
  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-secondary);
  }
  .post-body :global(h2) { margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .post-body :global(h3) { margin-top: 2rem; margin-bottom: 0.5rem; }
  .post-body :global(p) { margin-bottom: 1.25rem; color: var(--text-secondary); line-height: 1.8; }
  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .post-body :global(li::marker) { color: var(--accent-data); }
  .post-body :global(strong) { color: var(--text-primary); font-weight: 600; }
  .post-body :global(code) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .post-body :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 1.5rem 0;
    font-family: var(--font-quote);
    font-size: 1.1rem;
  }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>