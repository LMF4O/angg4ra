---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import StatusBadge from '../../../components/ui/StatusBadge.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, status, tags, metric, github, demo, date } = project.data;
---

<BaseLayout title={title} lang="en">
  <div class="page-container">

    <a href="/en/projects" class="back-link font-mono">← Back to Projects</a>

    <div class="project-header">
      <StatusBadge status={status} />
      <h1 style="margin-top: 0.75rem">{title}</h1>
      <p class="project-desc">{description}</p>

      {metric && (
        <div class="metric-badge font-mono">{metric}</div>
      )}

      <div class="tags">
        {tags.map(tag => <span class="tag font-mono">{tag}</span>)}
      </div>

      <div class="project-links">
        {github && (
          <a href={github} target="_blank" rel="noopener" class="btn-outline font-mono">
            GitHub →
          </a>
        )}
        {demo && (
          <a href={demo} target="_blank" rel="noopener" class="btn-outline btn-secondary font-mono">
            Demo →
          </a>
        )}
      </div>

      <p class="project-date font-mono">{date}</p>
    </div>

    <div class="project-body">
      <Content />
    </div>

  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 780px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .back-link {
    font-size: 0.8rem;
    color: var(--text-secondary);
    display: inline-block;
    margin-bottom: 2.5rem;
    transition: color 200ms ease;
  }
  .back-link:hover { color: var(--text-primary); }
  .project-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .project-desc {
    font-size: 1.1rem;
    margin-top: 0.75rem;
    color: var(--text-secondary);
  }
  .metric-badge {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--accent-data);
    border: 1px solid var(--accent-data);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
  }
  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .tag {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-secondary);
  }
  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .btn-outline {
    font-size: 0.8rem;
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--accent);
    color: var(--text-primary);
    border-radius: var(--radius);
    transition: all 250ms ease;
  }
  .btn-outline:hover { background-color: var(--accent); color: var(--text-primary); }
  .btn-secondary { border-color: var(--border); }
  .btn-secondary:hover { background-color: var(--bg-card); box-shadow: none; }
  .project-date {
    margin-top: 1.25rem;
    font-size: 0.72rem;
    color: var(--text-secondary);
    opacity: 0.6;
  }
  .project-body :global(h2) { margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .project-body :global(h3) { margin-top: 2rem; margin-bottom: 0.5rem; }
  .project-body :global(p) { margin-bottom: 1rem; color: var(--text-secondary); }
  .project-body :global(ul),
  .project-body :global(ol) {
    padding-left: 1.5rem;
    color: var(--text-secondary);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .project-body :global(li::marker) { color: var(--accent-data); }
  .project-body :global(strong) { color: var(--text-primary); font-weight: 600; }
  .project-body :global(code) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .project-body :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .project-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>