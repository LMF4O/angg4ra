---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import BentoCard from '../../components/ui/BentoCard.astro';
---

<BaseLayout title="Contact" lang="en">
  <div class="page-container">
    <h1 class="page-title">Contact</h1>
    <p style="color: var(--text-secondary); margin-bottom: 3rem; max-width: 500px">
      I usually reply within 24 to 48 hours.
    </p>

    <div class="bento-grid">
      <div class="bento-main">
        <BentoCard size="lg" scanline={true}>
          <div class="terminal-header font-mono">
            <span style="color: var(--accent-data)">&gt;</span>
            <span style="color: var(--text-secondary)"> compose_message</span>
          </div>

          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <input type="text" id="name" placeholder="> Your name..." class="terminal-input font-mono" required />
            </div>
            <div class="form-group">
              <input type="email" id="email" placeholder="> Your email..." class="terminal-input font-mono" required />
            </div>
            <div class="form-group">
              <div class="select-wrapper">
                <select id="subject" class="terminal-input font-mono">
                  <option value="">› Select a topic...</option>
                  <option value="collaboration">Collaboration</option>
                  <option value="internship">Internship / Job</option>
                  <option value="question">Question</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <textarea id="message" placeholder="> Your message..." class="terminal-input font-mono" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn-transmit font-mono" id="submit-btn">
              transmit_ →
            </button>
          </form>
        </BentoCard>
      </div>

      <div class="bento-sidebar">
        <BentoCard size="sm">
          <h3 class="font-mono" style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 1.5rem">/ connect</h3>
          <div class="contact-links">
            <a href="https://github.com/4RGY" target="_blank" rel="noopener" class="contact-link font-mono">
              <span class="link-label">GitHub</span>
              <span class="link-url">@4RGY</span>
            </a>
            <a href="https://linkedin.com/in/argy-anggara" target="_blank" rel="noopener" class="contact-link font-mono">
              <span class="link-label">LinkedIn</span>
              <span class="link-url">Argy Anggara</span>
            </a>
            <a href="mailto:rgyanggara@gmail.com" class="contact-link font-mono">
              <span class="link-label">Email</span>
              <span class="link-url">rgyanggara@gmail.com</span>
            </a>
          </div>

          <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border)">
            <p class="font-mono" style="font-size: 0.7rem; color: var(--text-secondary)">📍 Bekasi, Indonesia</p>
          </div>
        </BentoCard>
      </div>
    </div>
  </div>

  <div id="custom-alert" class="custom-alert-overlay" aria-hidden="true">
    <div class="custom-alert-box font-mono">
      <div class="alert-scanline"></div>
      <div class="alert-header">
        <span class="alert-title-text">[ SYSTEM NOTIFICATION ]</span>
        <button type="button" class="alert-close-x" id="alert-close-x-btn">&times;</button>
      </div>
      <div class="alert-body">
        <span class="alert-prompt">&gt;</span>
        <p id="alert-message-text">Initializing transmission...</p>
      </div>
      <div class="alert-footer">
        <button type="button" class="btn-alert-ok" id="alert-ok-btn">acknowledge_</button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-container { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 6rem 2rem; 
  }
  
  .page-title { 
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.5rem; 
    letter-spacing: -0.02em;
  }
  
  /* Modern Bento Grid Layout */
  .bento-grid { 
    display: grid; 
    grid-template-columns: repeat(12, 1fr); 
    gap: 1.5rem; 
    margin-top: 2rem;
  }
  .bento-main { grid-column: span 8; }
  .bento-sidebar { grid-column: span 4; }

  .terminal-header { 
    font-size: 0.8rem; 
    margin-bottom: 2rem; 
    border-bottom: 1px dashed var(--border);
    padding-bottom: 0.75rem;
  }
  
  .form-group { 
    margin-bottom: 1.5rem; 
    position: relative;
  }
  
  /* Terminal Input Reset & Styling */
  .terminal-input {
    width: 100%;
    background: rgba(20, 20, 20, 0.4);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    transition: all 250ms ease;
    outline: none;
    resize: vertical;
    box-sizing: border-box;
  }
  
  .terminal-input:focus { 
    border-color: var(--accent-data); 
    background: rgba(107, 45, 62, 0.05);
    box-shadow: 0 0 12px rgba(107, 45, 62, 0.15);
  }
  
  .terminal-input::placeholder { 
    color: rgba(255, 255, 255, 0.3); 
  }

  .select-wrapper {
    position: relative;
    width: 100%;
  }
  
  .select-wrapper::after {
    content: "▼";
    font-size: 0.7rem;
    color: var(--text-secondary);
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    transition: color 200ms ease;
  }
  
  .select-wrapper:focus-within::after {
    color: var(--accent-data);
  }

  select.terminal-input { 
    appearance: none; 
    cursor: pointer;
    padding-right: 2.5rem;
  }
  
  select.terminal-input option {
    background-color: #121212;
    color: var(--text-primary);
    padding: 10px;
    font-family: var(--font-mono);
  }

  .btn-transmit {
    margin-top: 0.5rem;
    padding: 0.75rem 2rem;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--text-primary);
    font-size: 0.85rem;
    cursor: pointer;
    border-radius: var(--radius);
    transition: all 250ms ease;
    letter-spacing: 0.05em;
  }
  
  .btn-transmit:hover:not(:disabled) { 
    background: var(--accent); 
    box-shadow: 0 0 20px rgba(107, 45, 62, 0.4);
    color: #fff;
  }

  .btn-transmit:disabled {
    border-color: var(--border);
    color: var(--text-secondary);
    cursor: not-allowed;
  }
  
  .contact-links { 
    display: flex; 
    flex-direction: column; 
    gap: 1.5rem; 
  }
  
  .contact-link { 
    display: flex; 
    flex-direction: column; 
    gap: 0.25rem; 
    text-decoration: none; 
    padding: 0.75rem;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid transparent;
    transition: all 200ms ease;
  }
  
  .link-label { 
    font-size: 0.65rem; 
    text-transform: uppercase; 
    letter-spacing: 0.1em; 
    color: var(--text-secondary); 
  }
  
  .link-url { 
    color: var(--text-primary); 
    font-size: 0.9rem; 
    transition: color 200ms ease; 
  }
  
  .contact-link:hover {
    border-color: rgba(107, 45, 62, 0.3);
    background: rgba(107, 45, 62, 0.05);
  }
  
  .contact-link:hover .link-url { 
    color: var(--accent-data); 
  }

  /* ── CUSTOM SCIFI ALERT STYLING ── */
  .custom-alert-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: rgba(5, 5, 5, 0.85);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  /* JS-triggered active class */
  .custom-alert-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .custom-alert-box {
    position: relative;
    width: 90%;
    max-width: 450px;
    background: #0f0f11;
    border: 1px solid var(--accent);
    box-shadow: 0 0 30px rgba(107, 45, 62, 0.25);
    border-radius: 4px;
    overflow: hidden;
    transform: scale(0.95);
    transition: transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .custom-alert-overlay.is-active .custom-alert-box {
    transform: scale(1);
  }

  /* CRT Scanline Effect */
  .alert-scanline {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
    background-size: 100% 4px, 6px 100%;
    pointer-events: none;
    opacity: 0.4;
  }

  .alert-header {
    background: rgba(107, 45, 62, 0.15);
    padding: 0.75rem 1.2rem;
    border-bottom: 1px solid rgba(107, 45, 62, 0.3);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .alert-title-text {
    font-size: 0.75rem;
    color: var(--accent-data);
    letter-spacing: 0.1em;
    font-weight: bold;
  }

  .alert-close-x {
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 1.2rem;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }
  .alert-close-x:hover { color: var(--accent-data); }

  .alert-body {
    padding: 2rem 1.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .alert-prompt {
    color: var(--accent-data);
    font-weight: bold;
    animation: blink 1s step-end infinite;
  }

  #alert-message-text {
    font-size: 0.9rem;
    color: var(--text-primary);
    line-height: 1.5;
    margin: 0;
  }

  .alert-footer {
    padding: 1rem 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: flex-end;
    background: rgba(0, 0, 0, 0.2);
  }

  .btn-alert-ok {
    background: transparent;
    border: 1px solid var(--text-secondary);
    color: var(--text-primary);
    padding: 0.4rem 1.2rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    cursor: pointer;
    border-radius: 2px;
    transition: all 150ms ease;
  }

  .btn-alert-ok:hover {
    border-color: var(--accent-data);
    background: var(--accent);
    color: #fff;
    box-shadow: 0 0 10px rgba(107, 45, 62, 0.4);
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  @media (max-width: 968px) {
    .bento-main { grid-column: span 12; }
    .bento-sidebar { grid-column: span 12; }
    .page-container { padding: 4rem 1.5rem; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  // DOM elements for the Custom Terminal Alert
  const alertOverlay = document.getElementById('custom-alert');
  const alertMessage = document.getElementById('alert-message-text');
  const alertCloseX = document.getElementById('alert-close-x-btn');
  const alertOkBtn = document.getElementById('alert-ok-btn');

  // Function to trigger the modal alert replacing native alert()
  function triggerTerminalAlert(message: string) {
    if (alertOverlay && alertMessage) {
      alertMessage.textContent = message;
      alertOverlay.classList.add('is-active');
      alertOverlay.setAttribute('aria-hidden', 'false');
    }
  }

  function closeTerminalAlert() {
    if (alertOverlay) {
      alertOverlay.classList.remove('is-active');
      alertOverlay.setAttribute('aria-hidden', 'true');
    }
  }

  // Event handlers for closing the modal
  alertCloseX?.addEventListener('click', closeTerminalAlert);
  alertOkBtn?.addEventListener('click', closeTerminalAlert);
  
  // Close if outer overlay area is clicked
  alertOverlay?.addEventListener('click', (e) => {
    if (e.target === alertOverlay) closeTerminalAlert();
  });

  // Main Formspree Submit Logic
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nameEl = document.getElementById('name') as HTMLInputElement | null;
    const emailEl = document.getElementById('email') as HTMLInputElement | null;
    const subjectEl = document.getElementById('subject') as HTMLSelectElement | null;
    const messageEl = document.getElementById('message') as HTMLTextAreaElement | null;

    const name = nameEl?.value;
    const email = emailEl?.value;
    const subject = subjectEl?.value;
    const message = messageEl?.value;

    if (!name || !email || !message) {
      triggerTerminalAlert('CRITICAL ERROR: Please fill in all required fields.');
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'transmitting_...';
    }

    try {
      const response = await fetch('https://formspree.io/f/xpqekojg', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, subject, message })
      });

      if (response.ok) {
        triggerTerminalAlert('TRANSMISSION SUCCESSFUL: Message sent via Formspree protocol.');
        form.reset();
      } else {
        triggerTerminalAlert('TRANSMISSION FAILED: Failed to deliver data packet. Please try again.');
      }
    } catch (error) {
      console.error('Error transmitting message:', error);
      triggerTerminalAlert('NETWORK ERROR: Server connection interference detected.');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'transmit_ →';
      }
    }
  });
</script>