---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import BentoCard from '../../components/ui/BentoCard.astro';
import FeaturedProjects from '../../components/sections/FeaturedProjects.astro';

const experiences = [
  {
    role: 'Coding Educator',
    company: 'PT DigiKidz Indonesia',
    location: 'Cibubur, East Jakarta',
    period: 'Jan 2024 — Present',
    type: 'Part-time',
    color: '#6A8F6E',
    points: [
      'Teaching programming fundamentals, computational thinking, and computer logic to students.',
      'Compiling structured per-session learning reports for each student.',
      'Adapting teaching materials to each child\'s individual comprehension level.',
      'Introducing algorithm and logic concepts through games and small projects.',
    ],
  },
  {
    role: 'Freelance Web Developer',
    company: 'Independent',
    location: 'Remote',
    period: '2023 — 2024',
    type: 'Freelance',
    color: '#3A6B7A',
    points: [
      'Built profile and portfolio websites for individual clients.',
      'Developed landing pages using vanilla HTML, CSS, and JavaScript.',
      'Coordinated directly with clients on design and content requirements.',
    ],
  },
  {
    role: 'Software Patent Holder',
    company: 'Desa Ciherang',
    location: 'Indonesia',
    period: '2025',
    type: 'Achievement',
    color: '#6B2D3E',
    points: [
      'Successfully registered a software copyright/patent for a village tourism website with registration number EC00202500538.',
      'Project developed as a digital promotion solution for a local tourism village.',
    ],
  },
  {
    role: 'Backend Developer',
    company: 'SMK Negeri 24 Jakarta',
    location: 'Jakarta',
    period: '2022',
    type: 'Part-time',
    color: '#7A6B3A',
    points: [
      'Contributed to the development of a Professional Certification Institute (LSP) website for a school institution.',
      'Designed and integrated APIs and optimized backend logic flow.',
    ],
  },
];

const education = [
  {
    degree: 'S1 Information Systems',
    institution: 'Universitas Indraprasta PGRI (UNINDRA)',
    period: '2023 - Present',
    gpa: '3.77',
    color: '#3A6B7A',
    highlights: [
      'Focused on data analysis, machine learning, and database management.',
      'Actively collaborating in group projects to design digital solutions.',
      'Studying the implementation of intelligent algorithms for business information processing.',
    ],
  },
  {
    degree: 'SMK Negeri 24 Jakarta',
    institution: 'Software Engineering',
    period: '2020 — 2023',
    gpa: null,
    color: '#6A8F6E',
    highlights: [
      'Where the rabbit hole of code began.',
      'Fundamentals of programming, databases, and application development.',
    ],
  },
];

const certifications = [
  { name: 'Belajar Machine Learning untuk Pemula', issuer: 'Dicoding', year: '2024' },
  { name: 'Python for Data Science',               issuer: 'Kaggle',   year: '2024' },
  { name: 'SQL for Data Analysis',                 issuer: 'Kaggle',   year: '2024' },
  { name: 'Data Visualization',                    issuer: 'Kaggle',   year: '2024' },
  { name: 'Intro to Machine Learning',             issuer: 'Kaggle',   year: '2024' },
  { name: 'Intermediate Machine Learning',         issuer: 'Kaggle',   year: '2024' },
  { name: 'Belajar Dasar SQL',                     issuer: 'Dicoding', year: '2024' },
  { name: 'Belajar Analisis Data dengan Python',   issuer: 'Dicoding', year: '2024' },
  { name: 'Belajar Dasar AI',                      issuer: 'Dicoding', year: '2024' },
  { name: 'Belajar Membuat Aplikasi Web',          issuer: 'Dicoding', year: '2023' },
  { name: 'Feature Engineering',                   issuer: 'Kaggle',   year: '2024' },
  { name: 'Pandas',                                issuer: 'Kaggle',   year: '2024' },
];

// Data analyst tools — used for the logo marquee.
const dataTools = [
  { name: 'Python',       slug: 'python' },
  { name: 'Pandas',       slug: 'pandas' },
  { name: 'NumPy',        slug: 'numpy' },
  { name: 'Scikit-learn', slug: 'scikitlearn' },
  { name: 'SQL',          slug: 'mysql' },
  { name: 'SHAP',         slug: 'shap' },
  { name: 'Jupyter',      slug: 'jupyter' },
  { name: 'Matplotlib',   slug: 'matplotlib' },
  { name: 'Seaborn',      slug: 'seaborn' },
  { name: 'Excel',        slug: 'microsoftexcel' },
];
// Duplicate the list so the marquee feels full & the loop is seamless (no gap in the middle).
const dataToolsLoop = [...dataTools, ...dataTools, ...dataTools];
---

<BaseLayout title="Home" lang="en">

  <Hero lang="en" />

  <!-- ══════════════════════════════════
       ABOUT — Bento Grid
  ══════════════════════════════════ -->
  <section class="page-section" id="about">
    <div class="glow glow-red" aria-hidden="true"></div>
    <div class="section-wrap">

      <div class="section-marker">
        <span class="marker-line"></span>
        <p class="marker-label font-mono">/ about</p>
      </div>

      <div class="bento-grid">

        <!-- Photo -->
        <div class="g-3">
          <BentoCard size="sm">
            <div class="photo-wrap">
              <img src="/images/argy.png" alt="Argy Anggara">
              <div class="photo-glow" aria-hidden="true"></div>
            </div>
          </BentoCard>
        </div>

        <!-- Bio -->
        <div class="g-9">
          <BentoCard size="lg">
            <p class="card-eyebrow font-mono">/ who i am</p>
            <p class="bio-text">
              I'm Argy Anggara, an Information Systems student with a strong interest in web development, data analysis, and machine learning. For me, data has always been a fascinating thing to explore — not just another work tool.
            </p>
            <p class="bio-text">
              I enjoy tinkering with functional projects, experimenting with intelligent models, and finding patterns behind information. My principle: a good system isn't one that's complex — it's one that others can understand most easily.
            </p>
            <div class="bio-tags">
              {['Machine Learning', 'Data Analysis', 'Web Dev', 'Teaching', 'INTP'].map(t => (
                <span class="bio-tag font-mono">{t}</span>
              ))}
            </div>
          </BentoCard>
        </div>

        <!-- Status -->
        <div class="g-4">
          <BentoCard size="sm">
            <p class="card-eyebrow font-mono">/ status</p>
            <div class="status-list">
              <div class="status-item">
                <span class="s-dot s-green"></span>
                <span>Open to Work</span>
              </div>
              <div class="status-item">
                <span class="s-dot s-teal"></span>
                <span>Building angg4ra.my.id</span>
              </div>
              <div class="status-item">
                <span class="s-dot s-red"></span>
                <span>@kodein.dulu</span>
              </div>
            </div>
          </BentoCard>
        </div>

        <!-- Currently -->
        <div class="g-4">
          <BentoCard size="sm">
            <p class="card-eyebrow font-mono">/ currently</p>
            <div class="current-list">
              <p>📖 Sherlock Holmes</p>
              <p>🎵 Listening R&B playlist</p>
              <p>🎮 Roblox development</p>
              <p>📊 Data Analyst & Data Scientist</p>
            </div>
          </BentoCard>
        </div>

        <!-- Stats -->
        <div class="g-4">
          <BentoCard size="sm">
            <p class="card-eyebrow font-mono">/ numbers</p>
            <div class="mini-stats">
              <div class="mini-stat">
                <span class="ms-val font-mono" style="color:#3A6B7A">8+</span>
                <span class="ms-lbl font-mono">Projects</span>
              </div>
              <div class="mini-stat">
                <span class="ms-val font-mono" style="color:#6B2D3E">12</span>
                <span class="ms-lbl font-mono">Certifications</span>
              </div>
            </div>
          </BentoCard>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════
       SKILLS — Logo marquee
       (focused on data analyst tools)
  ══════════════════════════════════ -->
  <section class="page-section skills-section" id="skills">
    <div class="glow glow-teal" aria-hidden="true"></div>
    <div class="section-wrap">

      <div class="section-marker">
        <span class="marker-line"></span>
        <p class="marker-label font-mono">/ skills</p>
      </div>
      <p class="section-desc">Tools I use to process and make sense of data.</p>

    </div>

    <!-- Logo marquee — full bleed, outside max-width of section-wrap -->
    <div class="logo-marquee" aria-label={dataTools.map(t => t.name).join(', ')}>

      <!-- Row 1: scroll left -->
      <div class="marquee-row marquee-row--left">
        <div class="marquee-track">
          {dataToolsLoop.map(tool => (
            <span class="marquee-logo" title={tool.name} data-fallback={tool.name}>
              <img
                src={`https://cdn.simpleicons.org/${tool.slug}`}
                alt={tool.name} width="56" height="56" loading="lazy"
                onerror="this.style.display='none'; this.parentElement.classList.add('marquee-logo--fallback');"
              />
            </span>
          ))}
        </div>
      </div>

      <!-- Row 2: scroll right -->
      <div class="marquee-row marquee-row--right">
        <div class="marquee-track">
          {dataToolsLoop.map(tool => (
            <span class="marquee-logo" title={tool.name} data-fallback={tool.name}>
              <img
                src={`https://cdn.simpleicons.org/${tool.slug}`}
                alt={tool.name} width="56" height="56" loading="lazy"
                onerror="this.style.display='none'; this.parentElement.classList.add('marquee-logo--fallback');"
              />
            </span>
          ))}
        </div>
      </div>

    </div>

  </section>

  <!-- ══════════════════════════════════
       EXPERIENCE — Independent scroll
  ══════════════════════════════════ -->
  <section class="page-section" id="experience">
    <div class="glow glow-red" style="left:auto;right:-15%;top:10%" aria-hidden="true"></div>
    <div class="section-wrap">

      <div class="section-marker">
        <span class="marker-line"></span>
        <p class="marker-label font-mono">/ experience</p>
      </div>

      <!-- Stats strip -->
      <div class="stats-strip">
        {[
          { val: '1+',   lbl: 'Years Teaching', color: '#6A8F6E' },
          { val: '500+', lbl: 'Teaching Hours',  color: '#6B2D3E' },
          { val: '8+',   lbl: 'Projects',        color: '#6A8F6E' },
          { val: '12',   lbl: 'Certifications',  color: '#3A6B7A' },
        ].map(s => (
          <div class="stat-item">
            <span class="stat-val font-mono" style={`color:${s.color}`}>{s.val}</span>
            <span class="stat-lbl font-mono">{s.lbl}</span>
          </div>
        ))}
      </div>

      <!-- Three columns, each scrolls independently -->
      <div class="exp-columns">

        <!-- Work Experience -->
        <div class="exp-col">
          <p class="col-label font-mono">/ Work Experience</p>
          <div class="col-scroll">
            {experiences.map((exp, i) => (
              <div class="exp-row" data-index={i}>
                <div
                  class="exp-row-head"
                  role="button" tabindex="0"
                  data-toggle={`exp-${i}`}
                  aria-expanded="false"
                >
                  <div class="exp-head-left">
                    <span class="exp-dot" style={`background:${exp.color};box-shadow:0 0 6px ${exp.color}80`}></span>
                    <div>
                      <p class="exp-role">{exp.role}</p>
                      <p class="exp-company font-mono">{exp.company}</p>
                    </div>
                  </div>
                  <div class="exp-head-right">
                    <span class="exp-period font-mono">{exp.period}</span>
                    <span class="exp-chevron">+</span>
                  </div>
                </div>
                <div class="exp-detail" id={`exp-${i}`} hidden>
                  <p class="exp-loc font-mono">{exp.location} · {exp.type}</p>
                  <ul class="exp-points">
                    {exp.points.map(p => <li>{p}</li>)}
                  </ul>
                </div>
              </div>
            ))}
            <div class="open-row font-mono">
              <span class="open-dot"></span>
              Open to new opportunities
            </div>
          </div>
        </div>

        <!-- Education -->
        <div class="exp-col">
          <p class="col-label font-mono">/ Education</p>
          <div class="col-scroll">
            {education.map(edu => (
              <div class="edu-card">
                <div class="edu-accent" style={`background:${edu.color}`}></div>
                <div class="edu-body">
                  <div class="edu-top">
                    <div>
                      <p class="edu-degree">{edu.degree}</p>
                      <p class="edu-inst font-mono">{edu.institution}</p>
                    </div>
                    <div class="edu-right">
                      <span class="edu-period font-mono">{edu.period}</span>
                      {edu.gpa && (
                        <span class="edu-gpa font-mono" style={`color:${edu.color}`}>GPA {edu.gpa}</span>
                      )}
                    </div>
                  </div>
                  <ul class="edu-highlights">
                    {edu.highlights.map(h => <li>{h}</li>)}
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Certifications -->
        <div class="exp-col">
          <div class="col-label-row">
            <p class="col-label font-mono">/ Certifications</p>
            <span class="col-count font-mono">{certifications.length}</span>
          </div>
          <div class="col-scroll">
            {certifications.map(cert => (
              <div class="cert-row">
                <p class="cert-name">{cert.name}</p>
                <div class="cert-meta">
                  <span class="cert-issuer font-mono">{cert.issuer}</span>
                  <span class="cert-year font-mono">{cert.year}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <FeaturedProjects lang="en" />

</BaseLayout>

<script>
// Experience accordion
document.querySelectorAll('.exp-row-head').forEach(head => {
  const toggle = () => {
    const id = (head as HTMLElement).dataset.toggle!;
    const detail = document.getElementById(id);
    const chevron = head.querySelector('.exp-chevron');
    const isOpen = !detail?.hasAttribute('hidden');

    // close all
    document.querySelectorAll('.exp-detail').forEach(d => d.setAttribute('hidden', ''));
    document.querySelectorAll('.exp-chevron').forEach(c => { c.textContent = '+'; });
    document.querySelectorAll('.exp-row').forEach(r => r.classList.remove('open'));
    document.querySelectorAll('.exp-row-head').forEach(h => h.setAttribute('aria-expanded', 'false'));

    if (!isOpen && detail) {
      detail.removeAttribute('hidden');
      if (chevron) chevron.textContent = '−';
      head.closest('.exp-row')?.classList.add('open');
      head.setAttribute('aria-expanded', 'true');
    }
  };
  head.addEventListener('click', toggle);
  head.addEventListener('keydown', (e: Event) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Enter' || ke.key === ' ') { e.preventDefault(); toggle(); }
  });
});

// Glow parallax
document.addEventListener('mousemove', (e: MouseEvent) => {
  const x = (e.clientX / window.innerWidth - 0.5) * 25;
  const y = (e.clientY / window.innerHeight - 0.5) * 25;
  document.querySelectorAll<HTMLElement>('.glow').forEach(g => {
    g.style.transform = `translate(${x}px, ${y}px)`;
  });
});
</script>

<style>
/* ── LAYOUT ──────────────────────────────────────────────── */
.page-section {
  padding: 7rem 2rem;
  position: relative;
  overflow: hidden;
}
.section-wrap { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }
.section-marker { display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem; }
.marker-line { flex: 0 0 28px; height: 1px; background: var(--accent); opacity: 0.5; }
.marker-label { font-size: 0.7rem; color: var(--accent); letter-spacing: 0.18em; text-transform: uppercase; }
.section-desc { font-size: 0.92rem; color: var(--text-secondary); margin-bottom: 2.5rem; margin-top: -1.75rem; }
.card-eyebrow { font-size: 0.68rem; color: var(--text-secondary); letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 1rem; }

/* ── GLOW ────────────────────────────────────────────────── */
.glow {
  position: absolute; border-radius: 50%;
  pointer-events: none; z-index: 0; filter: blur(90px);
  transition: transform 0.9s ease;
}
.glow-red {
  width: 600px; height: 600px; top: -10%; left: -15%;
  background: radial-gradient(circle, rgba(107,45,62,0.18) 0%, transparent 70%);
}
.glow-teal {
  width: 500px; height: 500px; top: 10%; right: -10%;
  background: radial-gradient(circle, rgba(58,107,122,0.15) 0%, transparent 70%);
}

/* ── BENTO GRID ──────────────────────────────────────────── */
.bento-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem; }
.g-3  { grid-column: span 3; }
.g-4  { grid-column: span 4; }
.g-9  { grid-column: span 9; }

/* ── ABOUT ───────────────────────────────────────────────── */
.photo-wrap {
  position: relative; width: 100%; height: 100%; min-height: 220px;
  background: linear-gradient(135deg, #1A1714, #0E0D0A);
  display: flex; align-items: center; justify-content: center;
  border-radius: 2px;
}
.photo-placeholder {
  font-size: 2.5rem; color: rgba(255,255,255,0.08); letter-spacing: 0.1em;
}
.photo-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 110%, rgba(107,45,62,0.2) 0%, transparent 65%);
  pointer-events: none;
}
.bio-text { font-size: 0.93rem; color: var(--text-secondary); line-height: 1.85; margin-bottom: 0.85rem; }
.bio-text:last-of-type { margin-bottom: 1.25rem; }
.bio-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.bio-tag {
  font-size: 0.65rem; padding: 0.22rem 0.7rem;
  border: 1px solid rgba(255,255,255,0.07); border-radius: 999px;
  color: rgba(255,255,255,0.3);
  transition: border-color 200ms, color 200ms;
}
.bio-tag:hover { border-color: var(--accent); color: var(--text-primary); }

.status-list { display: flex; flex-direction: column; gap: 0.7rem; }
.status-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.88rem; color: var(--text-secondary); }
.s-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; animation: pdot 2s ease infinite; }
.s-green { background: #6A8F6E; }
.s-teal  { background: #3A6B7A; }
.s-red   { background: #6B2D3E; }
@keyframes pdot { 0%,100%{opacity:1} 50%{opacity:0.3} }

.current-list { display: flex; flex-direction: column; gap: 0.6rem; font-size: 0.88rem; color: var(--text-secondary); }
.current-list p { margin: 0; line-height: 1.4; }

.mini-stats { display: flex; flex-direction: column; gap: 1rem; }
.mini-stat { display: flex; align-items: baseline; gap: 0.6rem; }
.ms-val { font-size: 1.5rem; font-weight: 500; line-height: 1; }
.ms-lbl { font-size: 0.62rem; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.1em; }

/* ── SKILLS / CURVED LOOP ─────────────────────────────────── */
.skills-section {
  padding-bottom: 3rem;
}
.logo-marquee {
  position: relative;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1.5rem 0;
}
.marquee-row {
  position: relative;
  width: 100%;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
}
.marquee-track {
  display: flex;
  align-items: center;
  gap: 3.5rem;
  width: max-content;
  will-change: transform;
}
.marquee-row--left .marquee-track {
  animation: marqueeLeft 36s linear infinite;
}
.marquee-row--right .marquee-track {
  animation: marqueeRight 42s linear infinite;
}
.marquee-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72px;
  height: 72px;
  opacity: 0.7;
  filter: grayscale(0.15);
  transition: opacity 220ms, transform 220ms, filter 220ms;
}
.marquee-logo:hover {
  opacity: 1;
  filter: grayscale(0);
  transform: translateY(-4px) scale(1.08);
}
.marquee-logo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.marquee-logo--fallback {
  position: relative;
}
.marquee-logo--fallback::after {
  content: attr(data-fallback);
  font-family: var(--font-mono, monospace);
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.2;
  white-space: normal;
  padding: 0 2px;
}
@keyframes marqueeLeft {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.3334%); }
}
@keyframes marqueeRight {
  from { transform: translateX(-33.3334%); }
  to   { transform: translateX(0); }
}
@media (prefers-reduced-motion: reduce) {
  .marquee-row--left .marquee-track,
  .marquee-row--right .marquee-track { animation: none; }
}

/* ── STATS STRIP ─────────────────────────────────────────── */
.stats-strip {
  display: flex; margin-bottom: 3rem;
  border: 1px solid rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  gap: 0.3rem; padding: 1.4rem 1rem;
  border-right: 1px solid rgba(255,255,255,0.06);
  transition: background 200ms;
}
.stat-item:last-child { border-right: none; }
.stat-item:hover { background: rgba(255,255,255,0.025); }
.stat-val { font-size: 1.65rem; font-weight: 500; line-height: 1; }
.stat-lbl { font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.22); }

/* ── THREE COLUMNS ───────────────────────────────────────── */
.exp-columns {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr 0.9fr;
  gap: 1.5rem;
  align-items: start;
}
.exp-col { display: flex; flex-direction: column; }
.col-label {
  font-size: 0.68rem; color: var(--text-secondary);
  letter-spacing: 0.16em; text-transform: uppercase;
  margin-bottom: 0.85rem;
}
.col-label-row {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: 0.85rem;
}
.col-label-row .col-label { margin-bottom: 0; }
.col-count {
  font-size: 0.62rem; color: rgba(255,255,255,0.2);
  letter-spacing: 0.06em;
}

/* Scroll container — fixed height, independent scroll */
.col-scroll {
  height: 380px;
  overflow-y: auto;
  padding-right: 6px;
  scrollbar-width: thin;
  scrollbar-color: rgba(255,255,255,0.08) transparent;
}
.col-scroll::-webkit-scrollbar { width: 3px; }
